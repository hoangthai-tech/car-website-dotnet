@using CarWebsite.Models
@model News
@{ ViewData["Title"] = Model.Title; }

<div class="pt-24 pb-16 min-h-screen bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="text-sm text-gray-500 mb-6">
            <a asp-controller="Home" asp-action="Index" class="hover:text-brand">Trang chủ</a>
            <span class="mx-2">/</span>
            <a asp-controller="TinTuc" asp-action="Index" class="hover:text-brand">Tin tức</a>
            <span class="mx-2">/</span>
            <span class="text-gray-800 line-clamp-1">@Model.Title</span>
        </nav>
        <span class="inline-block bg-brand text-white text-xs font-semibold px-3 py-1 rounded-full mb-4">@Model.Category</span>
        <h1 class="text-3xl sm:text-4xl font-black text-navy mb-4 leading-tight">@Model.Title</h1>
        <p class="text-gray-400 text-sm mb-6">@Model.PublishedAt.ToString("dd/MM/yyyy") · @Model.ReadTime đọc</p>
        <div class="rounded-2xl overflow-hidden mb-8">
            <img src="@Model.Image" alt="@Model.Title" class="w-full object-cover" />
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm prose prose-lg max-w-none">
            <p class="text-gray-700 leading-relaxed text-lg mb-4">@Model.Excerpt</p>
            <p class="text-gray-700 leading-relaxed">@Model.Content</p>
        </div>
        <div class="mt-8">
            <a asp-controller="TinTuc" asp-action="Index" class="inline-flex items-center gap-2 text-brand font-semibold hover:gap-4 transition-all">
                ← Quay lại tin tức
            </a>
        </div>
    </div>
</div>
