@using CarWebsite.Models
@model List<News>
@{ ViewData["Title"] = "Tin Tức & Ưu Đãi"; }

<div class="pt-24 pb-16 min-h-screen bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-10">
            <div class="section-line mb-3"></div>
            <h1 class="text-3xl sm:text-4xl font-black text-navy">Tin Tức & Ưu Đãi</h1>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var n in Model)
            {
                <a asp-controller="TinTuc" asp-action="Detail" asp-route-slug="@n.Slug" class="group block">
                    <div class="rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 bg-white">
                        <div class="relative h-52 overflow-hidden">
                            <img src="@n.Image" alt="@n.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                            <span class="absolute top-3 left-3 bg-brand text-white text-xs font-semibold px-2.5 py-1 rounded-full">@n.Category</span>
                        </div>
                        <div class="p-5">
                            <p class="text-xs text-gray-400 mb-2">@n.PublishedAt.ToString("dd/MM/yyyy") · @n.ReadTime đọc</p>
                            <h3 class="font-bold text-navy leading-snug mb-2 group-hover:text-brand transition-colors line-clamp-2 text-lg">@n.Title</h3>
                            <p class="text-gray-500 text-sm line-clamp-2">@n.Excerpt</p>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</div>
