@using CarWebsite.Models
@model List<ServiceTicket>
@{
    ViewData["Title"] = "Phiếu Dịch Vụ";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var technicians = (ViewBag.Technicians as List<User>) ?? [];
    var usagesByTicket = (ViewBag.UsagesByTicket as Dictionary<Guid, List<SparePartUsage>>) ?? [];
    var parts = (ViewBag.Parts as List<SparePart>) ?? [];
    string StatusLabel(string s) => s switch { "received" => "Tiếp nhận", "assigned" => "Đã phân công", "inprogress" => "Đang sửa", "completed" => "Hoàn thành", "paid" => "Đã thanh toán", _ => s };
    string StatusCls(string s) => s switch { "received" => "bg-yellow-100 text-yellow-700", "assigned" => "bg-blue-100 text-blue-700", "inprogress" => "bg-orange-100 text-orange-700", "completed" => "bg-green-100 text-green-700", "paid" => "bg-gray-100 text-gray-500", _ => "bg-gray-100 text-gray-600" };
}
@if (TempData["Success"] != null) { <div class="bg-green-50 border border-green-200 text-green-800 rounded-xl p-3 mb-4 text-sm">@TempData["Success"]</div> }
@if (TempData["Warning"] != null) { <div class="bg-amber-50 border border-amber-200 text-amber-800 rounded-xl p-3 mb-4 text-sm">@TempData["Warning"]</div> }
@if (TempData["Error"] != null)   { <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-3 mb-4 text-sm">@TempData["Error"]</div> }

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-black text-navy">Phiếu Dịch Vụ</h1>
        <div class="flex gap-3 mt-1.5 text-xs">
            <span class="bg-yellow-100 text-yellow-700 px-2.5 py-1 rounded-lg font-semibold">@ViewBag.ChoPhanCong chờ phân công</span>
            <span class="bg-orange-100 text-orange-700 px-2.5 py-1 rounded-lg font-semibold">@ViewBag.DangSua đang sửa</span>
            <span class="bg-green-100 text-green-700 px-2.5 py-1 rounded-lg font-semibold">@ViewBag.HoanThanh hoàn thành</span>
        </div>
    </div>
    <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-brand hover:bg-red-700 text-white font-semibold px-4 py-2.5 rounded-xl text-sm flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Tiếp nhận xe
    </button>
</div>

<div class="space-y-4">
    @foreach (var t in Model)
    {
        var usages = usagesByTicket.TryGetValue(t.Id, out var us) ? us : [];
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-4 flex items-start justify-between gap-4">
                <div class="flex-1">
                    <div class="flex items-center gap-3 flex-wrap mb-2">
                        <span class="font-mono text-sm font-bold text-navy">@t.TicketCode</span>
                        <span class="font-mono text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-md">@t.LicensePlate</span>
                        <span class="text-xs px-2.5 py-1 rounded-full font-semibold @StatusCls(t.Status)">@StatusLabel(t.Status)</span>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-xs text-gray-600">
                        <div><span class="text-gray-400 block">Khách hàng</span><strong>@t.CustomerName</strong></div>
                        <div><span class="text-gray-400 block">SĐT</span><strong>@t.CustomerPhone</strong></div>
                        <div><span class="text-gray-400 block">ODO</span><strong>@t.Odometer.ToString("N0") km</strong></div>
                        <div><span class="text-gray-400 block">KTV phụ trách</span><strong>@(t.AssignedTechnician?.Name ?? "Chưa phân công")</strong></div>
                    </div>
                    <p class="text-xs text-gray-500 mt-1.5 italic">@t.Description</p>
                </div>
                <div class="text-right flex-shrink-0">
                    @if (t.TotalAmount > 0) { <p class="text-lg font-black text-brand">@((t.TotalAmount / 1_000_000).ToString("N0"))M ₫</p> }
                    <button onclick="toggleTicket('@t.Id')" class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-3 py-1.5 rounded-lg font-semibold mt-1">Chi tiết</button>
                </div>
            </div>

            <div id="ticket-@t.Id" class="hidden border-t border-gray-100">
                <div class="grid grid-cols-1 lg:grid-cols-3 divide-y lg:divide-y-0 lg:divide-x divide-gray-100">

                    @* Parts usage *@
                    <div class="p-4">
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-3">Phụ tùng sử dụng</h3>
                        @if (usages.Any())
                        {
                            <div class="space-y-1.5 mb-3">
                                @foreach (var u in usages)
                                {
                                    <div class="flex justify-between text-xs">
                                        <span class="text-gray-700">@(u.SparePart?.Name ?? "—") × @u.Quantity</span>
                                        <span class="font-semibold text-navy">@((u.Quantity * u.UnitPrice / 1_000).ToString("N0"))K ₫</span>
                                    </div>
                                }
                            </div>
                        }
                        @if (t.Status is "assigned" or "inprogress")
                        {
                            <form asp-action="DichVuPhuTungSuDung" asp-controller="Dashboard" method="post" class="space-y-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId" value="@t.Id" />
                                <select name="sparePartId" required class="w-full border border-gray-200 rounded-lg px-3 py-2 text-xs focus:outline-none">
                                    <option value="">-- Chọn phụ tùng --</option>
                                    @foreach (var p in parts) { <option value="@p.Id">@p.Name (@p.Stock @p.Unit)</option> }
                                </select>
                                <div class="flex gap-2">
                                    <input type="number" name="quantity" required min="1" value="1" placeholder="SL" class="w-20 border border-gray-200 rounded-lg px-3 py-2 text-xs focus:outline-none" />
                                    <button type="submit" class="flex-1 bg-orange-100 hover:bg-orange-200 text-orange-700 font-semibold py-2 rounded-lg text-xs">Ghi nhận</button>
                                </div>
                            </form>
                        }
                    </div>

                    @* Assign & Status *@
                    <div class="p-4">
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-3">Phân công kỹ thuật viên</h3>
                        @if (t.Status == "received")
                        {
                            <form asp-action="DichVuPhanCong" asp-controller="Dashboard" method="post" class="space-y-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId" value="@t.Id" />
                                <select name="technicianId" required class="w-full border border-gray-200 rounded-lg px-3 py-2 text-xs focus:outline-none">
                                    <option value="">-- Chọn KTV --</option>
                                    @foreach (var tech in technicians) { <option value="@tech.Id">@tech.Name</option> }
                                </select>
                                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg text-xs">Phân công</button>
                            </form>
                        }
                        else if (t.Status is "assigned" or "inprogress")
                        {
                            <p class="text-xs text-gray-500 mb-3">KTV: <strong>@(t.AssignedTechnician?.Name ?? "—")</strong></p>
                            <form asp-action="DichVuHoanThanh" asp-controller="Dashboard" method="post" class="space-y-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId" value="@t.Id" />
                                <div>
                                    <label class="block text-xs font-semibold text-gray-600 mb-1">Tiền công (₫)</label>
                                    <input type="number" name="laborCost" required min="0" step="10000" value="@t.LaborCost" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-xs focus:outline-none" />
                                </div>
                                <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-2 rounded-lg text-xs">Hoàn thành sửa chữa</button>
                            </form>
                        }
                        else if (t.Status == "completed")
                        {
                            <p class="text-xs text-gray-500 mb-1">Hoàn thành: @(t.CompletedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</p>
                        }
                    </div>

                    @* Payment & Summary *@
                    <div class="p-4">
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-3">Thanh toán</h3>
                        <div class="space-y-1.5 text-xs mb-3">
                            <div class="flex justify-between"><span class="text-gray-400">Tiền công</span><span class="font-semibold">@((t.LaborCost / 1_000).ToString("N0"))K ₫</span></div>
                            <div class="flex justify-between"><span class="text-gray-400">Phụ tùng</span><span class="font-semibold">@((t.TotalPartsCost / 1_000).ToString("N0"))K ₫</span></div>
                            <div class="flex justify-between border-t border-gray-100 pt-1.5 font-bold text-sm"><span>Tổng</span><span class="text-brand">@((t.TotalAmount / 1_000_000).ToString("N0"))M ₫</span></div>
                        </div>
                        @if (t.Status == "completed")
                        {
                            <form asp-action="DichVuThanhToan" asp-controller="Dashboard" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId" value="@t.Id" />
                                <button type="submit" class="w-full bg-brand hover:bg-red-700 text-white font-bold py-2 rounded-lg text-xs">Xác nhận thanh toán</button>
                            </form>
                        }
                        else if (t.Status == "paid")
                        {
                            <span class="text-xs bg-gray-100 text-gray-500 px-3 py-1.5 rounded-lg font-semibold block text-center">Đã thanh toán</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any()) { <div class="bg-white rounded-2xl p-12 text-center shadow-sm border border-gray-100 text-gray-400">Chưa có phiếu dịch vụ nào.</div> }
</div>

@* Add Ticket Modal *@
<div id="addModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-lg mx-4">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-black text-navy">Tiếp Nhận Xe Dịch Vụ</h2>
            <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">✕</button>
        </div>
        <form asp-action="DichVuPhieuAdd" asp-controller="Dashboard" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Biển số xe <span class="text-red-500">*</span></label>
                    <input type="text" name="licensePlate" required placeholder="51G-12345" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">ODO (km) <span class="text-red-500">*</span></label>
                    <input type="number" name="odometer" required min="0" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tên khách hàng <span class="text-red-500">*</span></label>
                    <input type="text" name="customerName" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Số điện thoại <span class="text-red-500">*</span></label>
                    <input type="text" name="customerPhone" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Yêu cầu / Triệu chứng <span class="text-red-500">*</span></label>
                <textarea name="description" required rows="3" placeholder="Xe bị tiếng ồn động cơ, kiểm tra và thay nhớt định kỳ..." class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 resize-none"></textarea>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="flex-1 border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold py-2.5 rounded-xl text-sm">Hủy</button>
                <button type="submit" class="flex-1 bg-brand hover:bg-red-700 text-white font-bold py-2.5 rounded-xl text-sm">Tạo phiếu tiếp nhận</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function toggleTicket(id) {
    document.getElementById('ticket-' + id).classList.toggle('hidden');
}
</script>
}
