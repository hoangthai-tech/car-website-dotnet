@{ ViewData["Title"] = "Cài Đặt"; Layout = "~/Views/Shared/_DashboardLayout.cshtml"; }

<h1 class="text-2xl font-black text-navy mb-6">Cài Đặt Hệ Thống</h1>

@if (TempData["Success"] != null)
{
    <div class="bg-green-50 border border-green-200 text-green-800 rounded-xl p-4 mb-4 text-sm">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 mb-4 text-sm">@TempData["Error"]</div>
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <h2 class="font-bold text-navy mb-4 text-lg">Thông tin hệ thống</h2>
        <div class="space-y-3">
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                <div>
                    <p class="font-semibold text-navy text-sm">Framework</p>
                    <p class="text-xs text-gray-500">ASP.NET Core MVC + SQL Server</p>
                </div>
                <span class="bg-green-100 text-green-700 text-xs font-semibold px-3 py-1 rounded-full">Active</span>
            </div>
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                <div>
                    <p class="font-semibold text-navy text-sm">Tên ứng dụng</p>
                    <p class="text-xs text-gray-500">AutoHT Car Management</p>
                </div>
            </div>
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                <div>
                    <p class="font-semibold text-navy text-sm">Hotline</p>
                    <p class="text-xs text-gray-500">1800 1234</p>
                </div>
            </div>
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                <div>
                    <p class="font-semibold text-navy text-sm">Địa chỉ</p>
                    <p class="text-xs text-gray-500">123 Đường Lê Lợi, Quận 1, TP. HCM</p>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <h2 class="font-bold text-navy mb-4 text-lg">Đổi mật khẩu Admin</h2>
        <form asp-action="CaiDatDoiMatKhau" asp-controller="Dashboard" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Mật khẩu hiện tại</label>
                <input type="password" name="currentPassword" required
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30"
                       placeholder="••••••••" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Mật khẩu mới</label>
                <input type="password" name="newPassword" required minlength="8"
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30"
                       placeholder="Tối thiểu 8 ký tự" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Xác nhận mật khẩu mới</label>
                <input type="password" name="confirmPassword" required
                       class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30"
                       placeholder="Nhập lại mật khẩu mới" />
            </div>
            <button type="submit"
                    class="w-full bg-brand hover:bg-red-700 text-white font-bold py-3 rounded-xl transition-colors text-sm">
                Đổi mật khẩu
            </button>
        </form>
    </div>
</div>
