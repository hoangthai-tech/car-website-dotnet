@using CarWebsite.Models
@model List<User>
@{
    ViewData["Title"] = "CRM Khách Hàng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var profiles = (ViewBag.Profiles as Dictionary<Guid, CustomerProfile>) ?? [];
    var notesByCustomer = (ViewBag.NotesByCustomer as Dictionary<Guid, List<CustomerNote>>) ?? [];
    var allCars = (ViewBag.AllCars as List<string>) ?? [];
}

@if (TempData["Success"] != null) { <div class="bg-green-50 border border-green-200 text-green-800 rounded-xl p-3 mb-4 text-sm">@TempData["Success"]</div> }

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-black text-navy">CRM — Quản Lý Tư Vấn</h1>
        <p class="text-sm text-gray-400 mt-0.5">Hồ sơ khách hàng + dòng thời gian tư vấn</p>
    </div>
    <form asp-action="KinhDoanhCRM" asp-controller="Dashboard" method="get" class="flex gap-2">
        <input type="text" name="q" value="@ViewBag.SearchQ" placeholder="Tìm tên, email..." class="border border-gray-200 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 w-56" />
        <button type="submit" class="bg-navy text-white px-4 py-2 rounded-xl text-sm font-semibold">Tìm</button>
    </form>
</div>

<div class="space-y-4">
    @foreach (var c in Model)
    {
        var prof = profiles.TryGetValue(c.Id, out var p) ? p : null;
        var notes = notesByCustomer.TryGetValue(c.Id, out var n) ? n : [];
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-4 flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-navy flex items-center justify-center text-white font-bold text-sm flex-shrink-0">@c.Name[0]</div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 flex-wrap">
                        <span class="font-bold text-navy">@c.Name</span>
                        <span class="text-xs text-gray-400">@c.Email</span>
                        @if (prof != null)
                        {
                            <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-semibold">@prof.Source</span>
                            if (!string.IsNullOrEmpty(prof.InterestedCarModel))
                            {
                                <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">🚗 @prof.InterestedCarModel</span>
                            }
                        }
                    </div>
                    @if (prof?.Summary != null) { <p class="text-xs text-gray-500 mt-1 italic">@prof.Summary</p> }
                </div>
                <button onclick="toggleCrm('@c.Id')" class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-3 py-1.5 rounded-lg font-semibold flex-shrink-0">Chi tiết</button>
            </div>

            <div id="crm-@c.Id" class="hidden border-t border-gray-100">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 divide-y lg:divide-y-0 lg:divide-x divide-gray-100">
                    @* Timeline *@
                    <div class="p-4">
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-3">Lịch sử tư vấn</h3>
                        <div class="space-y-2 max-h-48 overflow-y-auto mb-3">
                            @foreach (var note in notes)
                            {
                                <div class="flex gap-2">
                                    <div class="w-1.5 h-1.5 rounded-full bg-brand mt-1.5 flex-shrink-0"></div>
                                    <div>
                                        <p class="text-xs text-gray-700">@note.Content</p>
                                        <p class="text-xs text-gray-400">@note.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm") — @(note.CreatedBy?.Name ?? "—")</p>
                                    </div>
                                </div>
                            }
                            @if (!notes.Any()) { <p class="text-xs text-gray-300">Chưa có ghi chú nào.</p> }
                        </div>
                        <form asp-action="KinhDoanhNoteAdd" asp-controller="Dashboard" method="post" class="flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="customerId" value="@c.Id" />
                            <input type="text" name="content" required placeholder="Thêm ghi chú tư vấn..." class="flex-1 border border-gray-200 rounded-xl px-3 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-brand/30" />
                            <button type="submit" class="bg-brand text-white px-3 py-2 rounded-xl text-xs font-semibold">Lưu</button>
                        </form>
                    </div>
                    @* Edit Profile *@
                    <div class="p-4">
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-3">Hồ sơ CRM</h3>
                        <form asp-action="KinhDoanhCRMSave" asp-controller="Dashboard" method="post" class="space-y-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="customerId" value="@c.Id" />
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Nguồn khách</label>
                                <select name="source" class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-xs">
                                    @foreach (var src in new[] { "walk-in","online","referral","event","other" })
                                    { <option value="@src" selected="@(prof?.Source == src)">@src</option> }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Dòng xe quan tâm</label>
                                <input type="text" name="interestedCarModel" value="@prof?.InterestedCarModel" list="carList-@c.Id" class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-xs" />
                                <datalist id="carList-@c.Id">@foreach (var car in allCars) { <option value="@car" /> }</datalist>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">SĐT liên hệ</label>
                                <input type="text" name="phone" value="@prof?.Phone" class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-xs" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 mb-1">Tóm tắt nội bộ</label>
                                <textarea name="summary" rows="2" class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-xs resize-none">@prof?.Summary</textarea>
                            </div>
                            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-xl text-xs">Lưu hồ sơ</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any()) { <div class="bg-white rounded-2xl p-12 text-center text-gray-400 shadow-sm">Không tìm thấy khách hàng nào.</div> }
</div>

@section Scripts {
<script>
function toggleCrm(id) {
    const el = document.getElementById('crm-' + id);
    el.classList.toggle('hidden');
}
</script>
}
