@using CarWebsite.Models
@model List<VehicleUnit>
@{
    ViewData["Title"] = "Kho Xe — Từng Chiếc";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var cars   = (ViewBag.Cars as List<Car>) ?? [];
    var pdiMap = (ViewBag.PdiMap as Dictionary<Guid, PdiChecklist>) ?? [];
    string StatusLabel(string s) => s switch { "available" => "Còn trống", "reserved" => "Đã giữ chỗ", "repair" => "Chờ sửa", "sold" => "Đã bán", _ => s };
    string StatusCls(string s)   => s switch { "available" => "bg-green-100 text-green-700", "reserved" => "bg-blue-100 text-blue-700", "repair" => "bg-red-100 text-red-700", "sold" => "bg-gray-100 text-gray-500", _ => "bg-gray-100 text-gray-600" };
}
@if (TempData["Success"] != null) { <div class="bg-green-50 border border-green-200 text-green-800 rounded-xl p-3 mb-4 text-sm">@TempData["Success"]</div> }
@if (TempData["Error"] != null)   { <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-3 mb-4 text-sm">@TempData["Error"]</div> }

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-black text-navy">Kho Xe — Từng Chiếc</h1>
        <p class="text-sm text-gray-400 mt-0.5">Quản lý VIN, số máy, màu sắc và trạng thái từng xe</p>
    </div>
    <div class="flex gap-3">
        <div class="flex gap-2 text-xs">
            @foreach (var s in new[] { ("available","Còn trống","bg-green-100 text-green-700"), ("reserved","Giữ chỗ","bg-blue-100 text-blue-700"), ("repair","Chờ sửa","bg-red-100 text-red-700"), ("sold","Đã bán","bg-gray-100 text-gray-500") })
            { <span class="px-2.5 py-1.5 rounded-lg font-semibold @s.Item3">@Model.Count(v => v.Status == s.Item1) @s.Item2</span> }
        </div>
        <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-brand hover:bg-red-700 text-white font-semibold px-4 py-2.5 rounded-xl text-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Nhập xe
        </button>
    </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold text-gray-500 text-xs uppercase">VIN / Số máy</th>
                    <th class="text-left px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Mẫu xe</th>
                    <th class="text-left px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Màu sắc</th>
                    <th class="text-right px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Giá bán</th>
                    <th class="text-center px-4 py-3 font-semibold text-gray-500 text-xs uppercase">PDI</th>
                    <th class="text-left px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Trạng thái</th>
                    <th class="text-right px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var v in Model)
                {
                    var pdi = pdiMap.TryGetValue(v.Id, out var pd) ? pd : null;
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3.5">
                            <div class="font-mono text-xs font-bold text-navy">@v.Vin</div>
                            <div class="text-xs text-gray-400">Máy: @v.EngineNumber</div>
                        </td>
                        <td class="px-4 py-3.5 font-semibold text-gray-700">@(v.Car?.Name ?? "—")</td>
                        <td class="px-4 py-3.5 text-xs text-gray-600">
                            <div>NQ: @v.ExteriorColor</div>
                            <div class="text-gray-400">NT: @v.InteriorColor</div>
                        </td>
                        <td class="px-4 py-3.5 text-right font-semibold text-navy text-xs">@((v.ListPrice > 0 ? v.ListPrice / 1_000_000 : v.Car?.Price / 1_000_000 ?? 0).ToString("N0"))M</td>
                        <td class="px-4 py-3.5 text-center">
                            @if (pdi == null)
                            {
                                <a asp-action="PdiCreate" asp-controller="Dashboard" asp-route-vehicleUnitId="@v.Id" class="text-xs bg-yellow-100 hover:bg-yellow-200 text-yellow-700 px-2.5 py-1 rounded-lg font-semibold">PDI</a>
                            }
                            else if (pdi.OverallPassed)
                            {
                                <span class="text-xs bg-green-100 text-green-700 px-2.5 py-1 rounded-lg font-semibold">✓ Đạt</span>
                            }
                            else
                            {
                                <span class="text-xs bg-red-100 text-red-700 px-2.5 py-1 rounded-lg font-semibold">✗ Lỗi</span>
                            }
                        </td>
                        <td class="px-4 py-3.5">
                            <span class="text-xs px-2.5 py-1 rounded-full font-semibold @StatusCls(v.Status)">@StatusLabel(v.Status)</span>
                        </td>
                        <td class="px-4 py-3.5 text-right">
                            @if (v.Status != "sold")
                            {
                                <button onclick="openEditModal('@v.Id','@v.ExteriorColor','@v.InteriorColor','@v.PurchasePrice','@v.ListPrice','@v.Status')" class="text-xs bg-blue-100 hover:bg-blue-200 text-blue-700 px-3 py-1.5 rounded-lg font-semibold">Sửa</button>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="7" class="px-4 py-10 text-center text-gray-400">Kho trống. Nhập xe mới bằng nút trên.</td></tr> }
            </tbody>
        </table>
    </div>
</div>

@* Modal Nhập xe *@
<div id="addModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-black text-navy">Nhập Xe Mới Vào Kho</h2>
            <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">✕</button>
        </div>
        <form asp-action="KhoXeUnitAdd" asp-controller="Dashboard" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Số khung (VIN)</label>
                    <input type="text" name="vin" required placeholder="VF3XXXXXXX" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Số máy</label>
                    <input type="text" name="engineNumber" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Mẫu xe</label>
                <select name="carId" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30">
                    <option value="">-- Chọn mẫu xe --</option>
                    @foreach (var c in cars) { <option value="@c.Id">@c.Name (@c.Brand)</option> }
                </select>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Màu ngoại thất</label>
                    <input type="text" name="exteriorColor" required placeholder="Trắng Ngọc Trai" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Màu nội thất</label>
                    <input type="text" name="interiorColor" required placeholder="Đen" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Giá nhập (₫)</label>
                    <input type="number" name="purchasePrice" required step="1000000" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Giá bán (₫)</label>
                    <input type="number" name="listPrice" required step="1000000" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="flex-1 border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold py-2.5 rounded-xl text-sm">Hủy</button>
                <button type="submit" class="flex-1 bg-brand hover:bg-red-700 text-white font-bold py-2.5 rounded-xl text-sm">Nhập kho</button>
            </div>
        </form>
    </div>
</div>

@* Modal Sửa xe *@
<div id="editModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md mx-4">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-black text-navy">Cập Nhật Xe</h2>
            <button type="button" onclick="document.getElementById('editModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">✕</button>
        </div>
        <form asp-action="KhoXeUnitEdit" asp-controller="Dashboard" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="eid" />
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Màu ngoại thất</label>
                    <input type="text" name="exteriorColor" id="eExtColor" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Màu nội thất</label>
                    <input type="text" name="interiorColor" id="eIntColor" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Giá nhập</label>
                    <input type="number" name="purchasePrice" id="ePurchase" step="1000000" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Giá bán</label>
                    <input type="number" name="listPrice" id="eList" step="1000000" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Trạng thái</label>
                <select name="status" id="eStatus" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30">
                    <option value="available">Còn trống</option>
                    <option value="repair">Chờ sửa chữa</option>
                </select>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="document.getElementById('editModal').classList.add('hidden')" class="flex-1 border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold py-2.5 rounded-xl text-sm">Hủy</button>
                <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 rounded-xl text-sm">Lưu</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function openEditModal(id, extColor, intColor, purchase, list, status) {
    document.getElementById('eid').value      = id;
    document.getElementById('eExtColor').value= extColor;
    document.getElementById('eIntColor').value= intColor;
    document.getElementById('ePurchase').value = purchase;
    document.getElementById('eList').value    = list;
    document.getElementById('eStatus').value  = status;
    document.getElementById('editModal').classList.remove('hidden');
}
</script>
}
