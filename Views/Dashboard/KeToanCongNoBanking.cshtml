@using CarWebsite.Models
@model List<BankLoan>
@{
    ViewData["Title"] = "Công Nợ Ngân Hàng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var eligibleOrders = (ViewBag.EligibleOrders as List<Order>) ?? [];
}
@if (TempData["Success"] != null) { <div class="bg-green-50 border border-green-200 text-green-800 rounded-xl p-3 mb-4 text-sm">@TempData["Success"]</div> }
@if (TempData["Error"] != null)   { <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-3 mb-4 text-sm">@TempData["Error"]</div> }

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-black text-navy">Công Nợ Vay Ngân Hàng</h1>
        <p class="text-sm text-gray-400 mt-0.5">Theo dõi hồ sơ vay & xác nhận giải ngân</p>
    </div>
    <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-brand hover:bg-red-700 text-white font-semibold px-4 py-2.5 rounded-xl text-sm flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Thêm hồ sơ vay
    </button>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Đơn hàng</th>
                    <th class="text-left px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Ngân hàng</th>
                    <th class="text-right px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Số vay</th>
                    <th class="text-center px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Lãi / Năm</th>
                    <th class="text-center px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Trạng thái</th>
                    <th class="text-right px-4 py-3 font-semibold text-gray-500 text-xs uppercase">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var loan in Model)
                {
                    var cls = loan.Status switch { "disbursed" => "bg-green-100 text-green-700", "rejected" => "bg-red-100 text-red-600", _ => "bg-yellow-100 text-yellow-700" };
                    var lbl = loan.Status switch { "pending" => "Chờ duyệt", "disbursed" => "Đã giải ngân", "rejected" => "Từ chối", _ => loan.Status };
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3.5">
                            <div class="font-mono text-xs font-bold text-navy">@(loan.Order?.OrderCode ?? "—")</div>
                            <div class="text-xs text-gray-400">@(loan.Order?.Customer?.Name ?? "—")</div>
                        </td>
                        <td class="px-4 py-3.5 font-semibold text-gray-700">@loan.BankName</td>
                        <td class="px-4 py-3.5 text-right font-semibold text-navy text-xs">@((loan.LoanAmount / 1_000_000).ToString("N0"))M ₫</td>
                        <td class="px-4 py-3.5 text-center text-xs text-gray-600">@loan.InterestRate%/năm · @loan.LoanYears năm</td>
                        <td class="px-4 py-3.5 text-center">
                            <span class="text-xs px-2.5 py-1 rounded-full font-semibold @cls">@lbl</span>
                        </td>
                        <td class="px-4 py-3.5 text-right">
                            @if (loan.Status == "pending")
                            {
                                <form asp-action="KeToanGiaiNgan" asp-controller="Dashboard" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="loanId" value="@loan.Id" />
                                    <button type="submit" class="text-xs bg-green-100 hover:bg-green-200 text-green-700 px-3 py-1.5 rounded-lg font-semibold">Xác nhận giải ngân</button>
                                </form>
                            }
                            @if (loan.Status == "disbursed" && loan.DisbursedAt.HasValue)
                            {
                                <span class="text-xs text-gray-400">@loan.DisbursedAt.Value.ToLocalTime().ToString("dd/MM/yyyy")</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="6" class="px-4 py-10 text-center text-gray-400">Chưa có hồ sơ vay nào.</td></tr> }
            </tbody>
        </table>
    </div>
</div>

@* Add Loan Modal *@
<div id="addModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md mx-4">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-black text-navy">Thêm Hồ Sơ Vay Ngân Hàng</h2>
            <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">✕</button>
        </div>
        <form asp-action="KeToanCongNoAdd" asp-controller="Dashboard" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Đơn hàng <span class="text-red-500">*</span></label>
                <select name="orderId" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30">
                    <option value="">-- Chọn đơn hàng --</option>
                    @foreach (var o in eligibleOrders) { <option value="@o.Id">@o.OrderCode — @(o.Customer?.Name ?? "—")</option> }
                </select>
                @if (!eligibleOrders.Any()) { <p class="text-xs text-amber-600 mt-1">Không có đơn đủ điều kiện (cần trạng thái "Đã đặt cọc — Chờ thanh toán đủ").</p> }
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tên ngân hàng <span class="text-red-500">*</span></label>
                <input type="text" name="bankName" required placeholder="VD: Vietcombank, Techcombank..." class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
            </div>
            <div class="grid grid-cols-3 gap-3">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Số tiền vay (₫)</label>
                    <input type="number" name="loanAmount" required step="1000000" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Lãi (%/năm)</label>
                    <input type="number" name="interestRate" required step="0.1" value="9.5" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Số năm</label>
                    <input type="number" name="loanYears" required min="1" max="10" value="5" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Ghi chú</label>
                <input type="text" name="notes" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="flex-1 border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold py-2.5 rounded-xl text-sm">Hủy</button>
                <button type="submit" class="flex-1 bg-brand hover:bg-red-700 text-white font-bold py-2.5 rounded-xl text-sm">Lưu hồ sơ</button>
            </div>
        </form>
    </div>
</div>
