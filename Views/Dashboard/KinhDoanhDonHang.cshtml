@using CarWebsite.Models
@model List<Order>
@{
    ViewData["Title"] = "Đơn Hàng — Kinh Doanh";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="bg-green-50 border border-green-200 text-green-800 rounded-xl p-4 mb-4 text-sm">@TempData["Success"]</div>
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-black text-navy">Đơn Hàng &amp; Hợp Đồng</h1>
        <p class="text-sm text-gray-400 mt-0.5">Lập báo giá, tạo hợp đồng đặt cọc / mua bán xe</p>
    </div>
</div>

<div class="grid grid-cols-4 gap-4 mb-6">
    @foreach (var stat in new[] {
        ("📋", "Tổng đơn",     ((int)(ViewBag.TotalOrders   ?? 0)).ToString(), "text-navy"),
        ("⏳", "Chờ xử lý",   ((int)(ViewBag.PendingOrders ?? 0)).ToString(), "text-yellow-600"),
        ("💰", "Đã đặt cọc",  ((int)(ViewBag.DepositOrders ?? 0)).ToString(), "text-blue-600"),
        ("✅", "Hoàn tất",    ((int)(ViewBag.DoneOrders    ?? 0)).ToString(), "text-green-600")
    })
    {
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
            <div class="text-2xl mb-2">@stat.Item1</div>
            <p class="text-xs text-gray-400 mb-1">@stat.Item2</p>
            <p class="text-2xl font-black @stat.Item4">@stat.Item3</p>
        </div>
    }
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-5 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-bold text-navy">Danh sách đơn mua xe</h2>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50">
                <tr>
                    <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Mã đơn</th>
                    <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Khách hàng</th>
                    <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Xe</th>
                    <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Trạng thái</th>
                    <th class="text-right px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Giá trị</th>
                    <th class="text-center px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Cập nhật</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var o in Model)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-5 py-3.5 font-mono text-navy font-semibold text-xs">@o.OrderCode</td>
                        <td class="px-5 py-3.5">
                            <p class="font-semibold">@o.CustomerName</p>
                            <p class="text-xs text-gray-400">@o.Customer?.Email</p>
                        </td>
                        <td class="px-5 py-3.5 text-gray-600">@o.CarName</td>
                        <td class="px-5 py-3.5">
                            <span class="text-xs px-2.5 py-1 rounded-full font-semibold
                                @(o.Status == "Hoàn tất"    ? "bg-green-100 text-green-700" :
                                  o.Status == "Đã đặt cọc" ? "bg-blue-100 text-blue-700" :
                                  o.Status == "Đang lái thử"? "bg-yellow-100 text-yellow-700" :
                                  "bg-gray-100 text-gray-600")">
                                @o.Status
                            </span>
                        </td>
                        <td class="px-5 py-3.5 text-right font-semibold text-navy">@o.Amount.ToString("N0") ₫</td>
                        <td class="px-5 py-3.5 text-center">
                            @{
                                var kdAllowed = o.Status switch {
                                    "Khách đang xem xe"               => new[]{"Đang lái thử","Đã đặt cọc","Đã hủy"},
                                    "Chờ xử lý"                       => new[]{"Đang lái thử","Đã đặt cọc","Đã hủy"},
                                    "Đang lái thử"                    => new[]{"Đã đặt cọc","Đã hủy"},
                                    "Đã đặt cọc"                      => new[]{"Đang giao","Đã hủy"},
                                    "Chờ kế toán duyệt tiền"          => new[]{"Đã đặt cọc — Chờ thanh toán đủ","Chờ bàn giao xe","Đã hủy"},
                                    "Đã đặt cọc — Chờ thanh toán đủ" => new[]{"Chờ bàn giao xe","Đã hủy"},
                                    "Chờ bàn giao xe"                 => new[]{"Đang giao","Đã hủy"},
                                    "Đang giao"                       => new[]{"Hoàn tất"},
                                    _                                 => Array.Empty<string>()
                                };
                            }
                            @if (kdAllowed.Length > 0) {
                                <form asp-action="KinhDoanhDonHangUpdateStatus" asp-controller="Dashboard" method="post" class="flex gap-1 justify-center" id="kd-form-@o.Id">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@o.Id" />
                                    <select name="status" class="text-xs border border-gray-200 rounded-lg px-2 py-1 focus:outline-none">
                                        @foreach (var s in kdAllowed) { <option value="@s">@s</option> }
                                    </select>
                                    <button type="button"
                                            onclick="var sel=this.previousElementSibling;showConfirmModal('Thay đổi trạng thái đơn hàng @o.OrderCode sang \"'+sel.value+'\"?',function(){document.getElementById('kd-form-@o.Id').submit();},'🔄','Xác nhận thay đổi')"
                                            class="text-xs bg-navy text-white px-2.5 py-1 rounded-lg hover:bg-navy/80">Lưu</button>
                                </form>
                            } else {
                                <span class="text-xs text-gray-400 italic">Không thể thay đổi</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="px-5 py-10 text-center text-gray-400">Chưa có đơn hàng nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
