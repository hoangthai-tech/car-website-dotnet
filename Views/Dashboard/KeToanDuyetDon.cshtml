@using CarWebsite.Models
@model List<Order>
@{
    ViewData["Title"] = "Duyệt Đơn & Thu Tiền";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var receiptsByOrder = (ViewBag.ReceiptsByOrder as Dictionary<Guid, List<PaymentReceipt>>) ?? [];
}
@if (TempData["Success"] != null) { <div class="bg-green-50 border border-green-200 text-green-800 rounded-xl p-3 mb-4 text-sm">@TempData["Success"]</div> }
@if (TempData["Error"] != null)   { <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-3 mb-4 text-sm">@TempData["Error"]</div> }

<div class="mb-6">
    <h1 class="text-2xl font-black text-navy">Duyệt Đơn & Thu Tiền</h1>
    <p class="text-sm text-gray-400 mt-0.5">Xác nhận thu cọc / thu đủ từng đơn hàng</p>
</div>

@if (!Model.Any())
{
    <div class="bg-white rounded-2xl p-12 text-center shadow-sm border border-gray-100">
        <p class="text-gray-400">Không có đơn hàng nào đang chờ duyệt tiền.</p>
    </div>
}
else
{
    <div class="space-y-5">
        @foreach (var o in Model)
        {
            var receipts = receiptsByOrder.TryGetValue(o.Id, out var rs) ? rs : [];
            var totalPaid = receipts.Sum(r => r.Amount);
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
                <div class="p-5 flex items-start justify-between gap-4">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 flex-wrap mb-2">
                            <span class="font-mono text-sm font-bold text-navy">@o.OrderCode</span>
                            <span class="text-xs bg-yellow-100 text-yellow-700 px-2.5 py-1 rounded-full font-semibold">@o.Status</span>
                        </div>
                        <div class="grid grid-cols-3 gap-4 text-sm">
                            <div><span class="text-xs text-gray-400 block">Khách hàng</span><strong class="text-gray-700">@(o.Customer?.Name ?? "—")</strong></div>
                            <div><span class="text-xs text-gray-400 block">Giá trị đơn</span><strong class="text-brand">@((o.Amount / 1_000_000).ToString("N0"))M ₫</strong></div>
                            <div><span class="text-xs text-gray-400 block">Đã thu</span><strong class="text-green-600">@((totalPaid / 1_000_000).ToString("N0"))M ₫</strong></div>
                        </div>
                    </div>
                    <button onclick="toggleReceipt('@o.Id')" class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-3 py-1.5 rounded-lg font-semibold flex-shrink-0">Thu tiền</button>
                </div>

                @* Receipt history *@
                @if (receipts.Any())
                {
                    <div class="px-5 pb-3 border-t border-gray-50">
                        <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mt-3 mb-2">Lịch sử phiếu thu</p>
                        <div class="space-y-1.5">
                            @foreach (var r in receipts)
                            {
                                var typeLabel = r.PaymentType switch { "deposit" => "Cọc", "partial" => "Thanh toán 1 phần", "full" => "Đủ tiền", "service" => "Dịch vụ", _ => r.PaymentType };
                                <div class="flex items-center gap-3 text-xs">
                                    <span class="font-mono font-bold text-navy w-36">@r.ReceiptCode</span>
                                    <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded-md font-semibold">@typeLabel</span>
                                    <span class="font-semibold text-gray-700">@((r.Amount / 1_000_000).ToString("N0"))M ₫</span>
                                    <span class="text-gray-400">@r.ConfirmedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* Receipt form *@
                <div id="receipt-@o.Id" class="hidden border-t border-gray-100 p-5 bg-gray-50 rounded-b-2xl">
                    <h3 class="text-sm font-bold text-navy mb-3">Xác nhận thu tiền</h3>
                    <form asp-action="KeToanXacNhanThu" asp-controller="Dashboard" method="post" class="grid grid-cols-2 gap-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@o.Id" />
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Loại thanh toán</label>
                            <select name="paymentType" required class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none">
                                <option value="deposit">Đặt cọc</option>
                                <option value="partial">Thanh toán 1 phần</option>
                                <option value="full">Thanh toán đủ</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Số tiền (₫)</label>
                            <input type="number" name="amount" required min="1" step="1000000" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none" />
                        </div>
                        <div class="col-span-2">
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Ghi chú</label>
                            <input type="text" name="notes" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none" />
                        </div>
                        <div class="col-span-2 flex gap-2">
                            <button type="button" onclick="toggleReceipt('@o.Id')" class="flex-1 border border-gray-200 bg-white hover:bg-gray-50 text-gray-600 font-semibold py-2 rounded-xl text-sm">Đóng</button>
                            <button type="submit" class="flex-1 bg-green-600 hover:bg-green-700 text-white font-bold py-2 rounded-xl text-sm">Tạo phiếu thu</button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
function toggleReceipt(id) {
    document.getElementById('receipt-' + id).classList.toggle('hidden');
}
</script>
}
