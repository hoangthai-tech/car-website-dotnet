@using CarWebsite.Models
@{
    ViewData["Title"] = "Tạo Đơn Đặt Cọc";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var customers = (ViewBag.Customers as List<User>) ?? [];
    var vehicles  = (ViewBag.AvailableVehicles as List<VehicleUnit>) ?? [];
}
@if (TempData["Error"] != null) { <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-3 mb-4 text-sm">@TempData["Error"]</div> }

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-black text-navy">Tạo Đơn Hàng & Đặt Cọc</h1>
        <p class="text-sm text-gray-400 mt-0.5">Chọn xe còn trống → nhập cọc → xe tự động chuyển "Đã giữ chỗ"</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <form asp-action="TaoDonHangSave" asp-controller="Dashboard" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Khách hàng <span class="text-red-500">*</span></label>
                <select name="customerId" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30">
                    <option value="">-- Chọn khách hàng --</option>
                    @foreach (var c in customers) { <option value="@c.Id">@c.Name — @c.Email</option> }
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Xe cần mua <span class="text-red-500">*</span> <span class="text-xs text-green-600 font-normal">(@vehicles.Count xe còn trống)</span></label>
                <select name="vehicleUnitId" required id="vehicleSelect" onchange="updatePrice(this)" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30">
                    <option value="">-- Chọn xe --</option>
                    @foreach (var v in vehicles)
                    {
                        var price = v.ListPrice > 0 ? v.ListPrice : v.Car.Price;
                        <option value="@v.Id" data-price="@price" data-name="@v.Car.Name" data-vin="@v.Vin" data-color="@v.ExteriorColor">
                            @v.Car.Name — @v.ExteriorColor — VIN: @v.Vin — @((price/1_000_000).ToString("N0"))M ₫
                        </option>
                    }
                </select>
            </div>
            <div id="vehicleInfo" class="hidden bg-blue-50 border border-blue-100 rounded-xl p-4 text-sm">
                <p class="font-semibold text-blue-800">Thông tin xe đã chọn</p>
                <div class="grid grid-cols-2 gap-2 mt-2 text-xs text-blue-700">
                    <div>Tên xe: <span id="vi-name" class="font-bold"></span></div>
                    <div>Màu: <span id="vi-color" class="font-bold"></span></div>
                    <div>VIN: <span id="vi-vin" class="font-bold font-mono"></span></div>
                    <div>Giá bán: <span id="vi-price" class="font-bold text-brand"></span></div>
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Số tiền đặt cọc (₫) <span class="text-red-500">*</span></label>
                <input type="number" name="depositAmount" required min="0" step="1000000" placeholder="50000000" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" />
                <p class="text-xs text-gray-400 mt-1">Thông thường đặt cọc 50–100 triệu ₫</p>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Ghi chú</label>
                <textarea name="notes" rows="3" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 resize-none" placeholder="Yêu cầu đặc biệt, phụ kiện kèm..."></textarea>
            </div>
            <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-sm text-yellow-800">
                <strong>Lưu ý:</strong> Sau khi lưu đơn, chiếc xe sẽ tự động chuyển sang trạng thái <strong>"Đã giữ chỗ"</strong> và đơn hàng sẽ chuyển tới Kế toán để duyệt tiền.
            </div>
            <div class="flex gap-3 pt-2">
                <a asp-action="KinhDoanhDonHang" asp-controller="Dashboard" class="flex-1 border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold py-3 rounded-xl text-sm text-center">Hủy</a>
                <button type="submit" class="flex-1 bg-brand hover:bg-red-700 text-white font-bold py-3 rounded-xl text-sm">Tạo Đơn Hàng</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function updatePrice(sel) {
    const opt = sel.options[sel.selectedIndex];
    if (!opt.value) { document.getElementById('vehicleInfo').classList.add('hidden'); return; }
    document.getElementById('vi-name').textContent  = opt.dataset.name;
    document.getElementById('vi-color').textContent = opt.dataset.color;
    document.getElementById('vi-vin').textContent   = opt.dataset.vin;
    document.getElementById('vi-price').textContent = new Intl.NumberFormat('vi-VN').format(opt.dataset.price) + ' ₫';
    document.getElementById('vehicleInfo').classList.remove('hidden');
}
</script>
}
