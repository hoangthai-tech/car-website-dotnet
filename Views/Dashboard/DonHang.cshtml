@using CarWebsite.Models
@model List<Order>
@{ ViewData["Title"] = "Quản lý đơn hàng"; Layout = "~/Views/Shared/_DashboardLayout.cshtml"; }

<h1 class="text-2xl font-black text-navy mb-6">Đơn Hàng</h1>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50">
                <tr>
                    <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Mã đơn</th>
                    <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Khách hàng</th>
                    <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Xe</th>
                    <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Trạng thái</th>
                    <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Giá trị</th>
                    <th class="text-right px-5 py-3 font-semibold text-gray-500 text-xs uppercase">Cập nhật</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var o in Model)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-5 py-3.5 font-mono text-xs font-semibold text-navy">@o.OrderCode</td>
                        <td class="px-5 py-3.5">@o.CustomerName</td>
                        <td class="px-5 py-3.5 text-gray-600">@o.CarName</td>
                        <td class="px-5 py-3.5">
                            <span class="text-xs px-2.5 py-1 rounded-full font-semibold
                                @(o.Status == "Hoàn tất" ? "bg-green-100 text-green-700" :
                                  o.Status == "Đã đặt cọc" ? "bg-blue-100 text-blue-700" :
                                  o.Status == "Đang lái thử" ? "bg-yellow-100 text-yellow-700" :
                                  "bg-gray-100 text-gray-600")">
                                @o.Status
                            </span>
                        </td>
                        <td class="px-5 py-3.5 font-semibold text-navy">@o.Amount.ToString("N0") ₫</td>
                        <td class="px-5 py-3.5 text-right">
                            <div class="flex gap-2 justify-end items-center">
                                @{
                                    var dhAllowed = o.Status switch {
                                        "Khách đang xem xe" => new[]{"Đang lái thử","Đã đặt cọc","Đã hủy"},
                                        "Chờ xử lý"         => new[]{"Đang lái thử","Đã đặt cọc","Đã hủy"},
                                        "Đang lái thử"      => new[]{"Đã đặt cọc","Đã hủy"},
                                        "Đã đặt cọc"        => new[]{"Đang giao","Đã hủy"},
                                        "Chờ bàn giao xe"   => new[]{"Đang giao","Đã hủy"},
                                        "Đang giao"         => new[]{"Hoàn tất"},
                                        _                   => Array.Empty<string>()
                                    };
                                }
                                @if (dhAllowed.Length > 0) {
                                    <form asp-action="DonHangUpdateStatus" asp-controller="Dashboard" method="post" class="flex gap-2 items-center" id="dh-form-@o.Id">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@o.Id" />
                                        <select name="status" class="border border-gray-200 rounded-lg px-2 py-1 text-xs focus:outline-none">
                                            @foreach (var s in dhAllowed) { <option value="@s">@s</option> }
                                        </select>
                                        <button type="button"
                                                onclick="var sel=this.previousElementSibling;showConfirmModal('Thay đổi trạng thái đơn '+sel.closest('form').querySelector('input[name=id]').value+'?',function(){document.getElementById('dh-form-@o.Id').submit();},'🔄','Xác nhận thay đổi')"
                                                class="text-xs bg-navy hover:bg-navy/90 text-white px-3 py-1.5 rounded-lg font-semibold transition-colors">Lưu</button>
                                    </form>
                                } else {
                                    <span class="text-xs text-gray-400 italic">Không đổi được</span>
                                }
                                <form asp-action="DonHangDelete" asp-controller="Dashboard" method="post" id="dh-del-@o.Id">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@o.Id" />
                                    <button type="button"
                                            onclick="showConfirmModal('Xóa đơn hàng @o.OrderCode của @Html.Raw(o.CustomerName.Replace("'","\\'")),function(){document.getElementById(\'dh-del-@o.Id\').submit();},'🗑️','Xóa đơn hàng')"
                                            class="text-xs bg-red-50 hover:bg-red-100 text-red-600 border border-red-200 px-3 py-1.5 rounded-lg font-semibold transition-colors">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="px-5 py-8 text-center text-gray-400">Chưa có đơn hàng nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
