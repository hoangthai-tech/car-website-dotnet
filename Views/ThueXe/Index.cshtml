@using CarWebsite.Models
@model List<Car>
@{ ViewData["Title"] = "Thuê Xe"; }

<div class="pt-24 pb-16 min-h-screen bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        @* ── Hero ── *@
        <div class="mb-10">
            <nav class="text-sm text-gray-500 mb-4">
                <a asp-controller="Home" asp-action="Index" class="hover:text-brand">Trang chủ</a>
                <span class="mx-2">/</span>
                <span class="text-gray-800">Thuê xe</span>
            </nav>
            <div class="section-line mb-3"></div>
            <h1 class="text-3xl sm:text-4xl font-black text-navy">Dịch Vụ Thuê Xe</h1>
            <p class="text-gray-500 mt-2">Xe sang trọng, tài xế chuyên nghiệp — đặt dễ dàng, nhận ngay.</p>
        </div>

        @* ── Perks ── *@
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
            @foreach (var p in new[] {
                ("M24 12C24 18.6274 18.6274 24 12 24C5.37258 24 0 18.6274 0 12C0 5.37258 5.37258 0 12 0C18.6274 0 24 5.37258 24 12Z", "Xe mới 100%", "Đảm bảo tiêu chuẩn chất lượng"),
                ("M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z", "Đặt xe 24/7", "Hotline luôn sẵn sàng"),
                ("M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z", "Tài xế chuyên nghiệp", "Kinh nghiệm, lịch sự"),
                ("M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z", "Thanh toán linh hoạt", "Tiền mặt hoặc chuyển khoản")
            })
            {
                <div class="bg-white rounded-2xl p-5 shadow-sm flex items-start gap-3 border border-gray-100">
                    <div class="w-10 h-10 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="@p.Item1"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-navy">@p.Item2</p>
                        <p class="text-xs text-gray-400 mt-0.5">@p.Item3</p>
                    </div>
                </div>
            }
        </div>

        @* ── Car Grid ── *@
        @if (!Model.Any())
        {
            <div class="text-center py-20">
                <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z"/>
                    </svg>
                </div>
                <p class="text-gray-500">Hiện chưa có xe cho thuê. Vui lòng quay lại sau.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var car in Model)
                {
                    <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
                        <div class="relative h-52 overflow-hidden">
                            <img src="@car.Image" alt="@car.Name"
                                 class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
                            @if (!string.IsNullOrEmpty(car.Badge))
                            {
                                <span class="absolute top-3 left-3 bg-brand text-white text-xs font-bold px-2.5 py-1 rounded-full">@car.Badge</span>
                            }
                            <span class="absolute top-3 right-3 bg-green-500 text-white text-xs font-semibold px-2.5 py-1 rounded-full flex items-center gap-1">
                                <span class="w-1.5 h-1.5 bg-white rounded-full inline-block"></span>
                                Có sẵn
                            </span>
                        </div>
                        <div class="p-5 flex-1 flex flex-col">
                            <div class="flex-1">
                                <p class="text-xs text-gray-400 mb-1">@car.Brand • @car.Year • @car.Type</p>
                                <h3 class="font-bold text-navy text-lg mb-3 leading-tight">@car.Name</h3>

                                @* Specs pills *@
                                <div class="flex flex-wrap gap-1.5 mb-4">
                                    <span class="bg-gray-100 text-gray-600 text-xs px-2.5 py-1 rounded-lg">@car.Fuel</span>
                                    <span class="bg-gray-100 text-gray-600 text-xs px-2.5 py-1 rounded-lg">@car.Specs.GetValueOrDefault("seats","5") chỗ</span>
                                    @if (!string.IsNullOrEmpty(car.Specs.GetValueOrDefault("transmission","")))
                                    {
                                        <span class="bg-gray-100 text-gray-600 text-xs px-2.5 py-1 rounded-lg">@car.Specs.GetValueOrDefault("transmission","")</span>
                                    }
                                    @if (!string.IsNullOrEmpty(car.Specs.GetValueOrDefault("power","")))
                                    {
                                        <span class="bg-blue-50 text-blue-700 text-xs px-2.5 py-1 rounded-lg">@car.Specs.GetValueOrDefault("power","")</span>
                                    }
                                </div>
                            </div>

                            @* Pricing + CTA *@
                            <div class="border-t border-gray-50 pt-4">
                                <div class="flex items-end justify-between mb-4">
                                    <div>
                                        <p class="text-xs text-gray-400">Giá thuê / ngày</p>
                                        <p class="text-brand font-black text-2xl leading-tight">@(car.RentalPricePerDay.ToString("N0")) ₫</p>
                                    </div>
                                    <a asp-controller="Xe" asp-action="Detail" asp-route-slug="@car.Slug"
                                       class="text-xs text-navy/50 hover:text-brand transition-colors flex items-center gap-1">
                                        Chi tiết
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                    </a>
                                </div>
                                <button
                                    data-car-id="@car.Id"
                                    data-car-name="@car.Name"
                                    data-car-rate="@car.RentalPricePerDay"
                                    data-car-image="@car.Image"
                                    data-car-brand="@car.Brand"
                                    onclick="openRentalModal(this)"
                                    class="w-full bg-brand hover:bg-red-700 text-white font-bold py-3 rounded-xl transition-colors text-sm flex items-center justify-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                    Đặt xe ngay
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@* ── Modal đặt thuê xe ── *@
<div id="modal-rental" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 px-4 py-6">
    <div class="bg-white rounded-2xl w-full max-w-lg shadow-2xl overflow-hidden" style="max-height:90vh;overflow-y:auto;">

        @* Modal header *@
        <div class="bg-navy px-6 py-4 flex items-center justify-between">
            <div>
                <p class="text-white/60 text-xs">Đặt thuê xe</p>
                <h3 class="text-white font-black text-lg" id="modal-car-name">—</h3>
            </div>
            <button onclick="closeRentalModal()" class="text-white/60 hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* Form panel *@
        <div id="rental-form-panel" class="p-6">

            @* Car preview *@
            <div class="flex items-center gap-4 bg-gray-50 rounded-xl p-4 mb-6">
                <img id="modal-car-image" src="" alt="" class="w-20 h-14 object-cover rounded-lg flex-shrink-0" />
                <div class="flex-1 min-w-0">
                    <p id="modal-car-brand" class="text-xs text-gray-400 truncate"></p>
                    <p id="modal-car-name2" class="font-bold text-navy text-sm truncate"></p>
                    <div class="flex items-center gap-1 mt-1">
                        <span class="text-brand font-black text-base" id="modal-car-rate-display">—</span>
                        <span class="text-xs text-gray-400">/ ngày</span>
                    </div>
                </div>
                <div class="text-right">
                    <span class="bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">Có sẵn</span>
                </div>
            </div>

            @* Date picker *@
            <form id="form-rental" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="carId" id="rental-car-id" />
                <input type="hidden" name="orderType" value="rent" />

                <div class="mb-5">
                    <h4 class="text-sm font-bold text-navy mb-3 flex items-center gap-2">
                        <span class="w-5 h-5 bg-brand text-white text-xs font-black rounded-full flex items-center justify-center">1</span>
                        Chọn ngày thuê
                    </h4>
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-semibold text-gray-500 mb-1.5">Ngày nhận xe</label>
                            <div class="relative">
                                <input type="date" name="rentalStartDate" id="r-start"
                                       min="@DateTime.Now.ToString("yyyy-MM-dd")"
                                       class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 pr-9" />
                                <svg class="w-4 h-4 text-gray-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-500 mb-1.5">Ngày trả xe</label>
                            <div class="relative">
                                <input type="date" name="rentalEndDate" id="r-end"
                                       min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")"
                                       class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 pr-9" />
                                <svg class="w-4 h-4 text-gray-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>

                @* Total summary — shown after valid dates *@
                <div id="rental-summary" class="hidden mb-5">
                    <h4 class="text-sm font-bold text-navy mb-3 flex items-center gap-2">
                        <span class="w-5 h-5 bg-brand text-white text-xs font-black rounded-full flex items-center justify-center">2</span>
                        Tóm tắt đơn thuê
                    </h4>
                    <div class="bg-gradient-to-br from-navy/5 to-brand/5 border border-navy/10 rounded-xl p-4 space-y-2.5">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-500">Ngày nhận xe</span>
                            <span class="font-semibold text-navy" id="sum-start">—</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-500">Ngày trả xe</span>
                            <span class="font-semibold text-navy" id="sum-end">—</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-500">Số ngày thuê</span>
                            <span class="font-semibold text-navy" id="sum-days">—</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-500">Đơn giá</span>
                            <span class="font-semibold text-navy" id="sum-rate">—</span>
                        </div>
                        <div class="border-t border-navy/10 pt-2.5 flex justify-between">
                            <span class="font-bold text-navy">Tổng ước tính</span>
                            <span class="font-black text-brand text-lg" id="sum-total">—</span>
                        </div>
                        <p class="text-xs text-gray-400">* Giá cuối có thể thay đổi sau khi nhân viên xác nhận.</p>
                    </div>
                </div>

                @* Error *@
                <div id="rental-error" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-xl p-3 mb-4 text-sm flex items-start gap-2">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span id="rental-error-msg"></span>
                </div>

                <div class="flex gap-3">
                    <button type="button" onclick="closeRentalModal()"
                            class="flex-1 border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold py-3 rounded-xl transition-colors text-sm">
                        Huỷ
                    </button>
                    <button type="submit" id="btn-rental"
                            class="flex-1 bg-brand hover:bg-red-700 text-white font-bold py-3 rounded-xl transition-colors text-sm flex items-center justify-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Xác nhận đặt xe
                    </button>
                </div>
            </form>
        </div>

        @* Success panel *@
        <div id="rental-success-panel" class="hidden p-8 text-center">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-5">
                <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <h3 class="text-2xl font-black text-navy mb-2">Đặt xe thành công!</h3>
            <p id="success-msg" class="text-gray-600 text-sm mb-1"></p>
            <div class="inline-flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-xl px-4 py-2 mb-6 mt-2">
                <span class="text-xs text-gray-400">Mã đơn:</span>
                <span id="success-code" class="font-black text-navy text-sm tracking-wider"></span>
            </div>
            <p class="text-xs text-gray-400 mb-6">Nhân viên sẽ liên hệ xác nhận lịch thuê trong vòng 30 phút.</p>
            <div class="flex gap-3">
                <button onclick="closeRentalModal()"
                        class="flex-1 border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold py-3 rounded-xl transition-colors text-sm">
                    Đóng
                </button>
                <a href="/Profile/Orders"
                   class="flex-1 bg-brand hover:bg-red-700 text-white font-bold py-3 rounded-xl transition-colors text-sm text-center flex items-center justify-center">
                    Xem đơn hàng
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const today = new Date().toISOString().split('T')[0];
    let currentRate = 0;

    // ── Mở modal ──
    window.openRentalModal = function (btn) {
        currentRate = parseInt(btn.dataset.carRate) || 0;
        document.getElementById('rental-car-id').value      = btn.dataset.carId;
        document.getElementById('modal-car-name').textContent  = btn.dataset.carName;
        document.getElementById('modal-car-name2').textContent = btn.dataset.carName;
        document.getElementById('modal-car-brand').textContent = btn.dataset.carBrand;
        document.getElementById('modal-car-image').src         = btn.dataset.carImage;
        document.getElementById('modal-car-rate-display').textContent =
            parseInt(btn.dataset.carRate).toLocaleString('vi-VN') + ' ₫';

        // reset form
        document.getElementById('r-start').value = '';
        document.getElementById('r-end').value   = '';
        document.getElementById('rental-summary').classList.add('hidden');
        document.getElementById('rental-error').classList.add('hidden');
        document.getElementById('rental-form-panel').classList.remove('hidden');
        document.getElementById('rental-success-panel').classList.add('hidden');
        const btn2 = document.getElementById('btn-rental');
        btn2.disabled = false;
        btn2.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Xác nhận đặt xe';

        document.getElementById('modal-rental').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    };

    window.closeRentalModal = function () {
        document.getElementById('modal-rental').classList.add('hidden');
        document.body.style.overflow = '';
    };

    // ── Đóng khi click backdrop ──
    document.getElementById('modal-rental').addEventListener('click', function (e) {
        if (e.target === this) closeRentalModal();
    });

    // ── Tính tổng ──
    function formatDate(d) {
        if (!d) return '—';
        const [y, m, day] = d.split('-');
        return `${day}/${m}/${y}`;
    }

    function recalc() {
        const s = document.getElementById('r-start').value;
        const e = document.getElementById('r-end').value;
        const summary = document.getElementById('rental-summary');
        if (!s || !e) { summary.classList.add('hidden'); return; }
        const days = Math.round((new Date(e) - new Date(s)) / 86400000);
        if (days < 1) { summary.classList.add('hidden'); return; }

        document.getElementById('sum-start').textContent = formatDate(s);
        document.getElementById('sum-end').textContent   = formatDate(e);
        document.getElementById('sum-days').textContent  = days + ' ngày';
        document.getElementById('sum-rate').textContent  = currentRate.toLocaleString('vi-VN') + ' ₫/ngày';
        document.getElementById('sum-total').textContent = (days * currentRate).toLocaleString('vi-VN') + ' ₫';
        summary.classList.remove('hidden');
    }

    document.getElementById('r-start').addEventListener('change', function () {
        const end = document.getElementById('r-end');
        const next = new Date(this.value); next.setDate(next.getDate() + 1);
        end.min = next.toISOString().split('T')[0];
        if (end.value && end.value <= this.value) end.value = '';
        recalc();
    });
    document.getElementById('r-end').addEventListener('change', recalc);

    // ── Submit ──
    document.getElementById('form-rental').addEventListener('submit', async function (e) {
        e.preventDefault();
        const errorBox = document.getElementById('rental-error');
        const errorMsg = document.getElementById('rental-error-msg');
        const btn = document.getElementById('btn-rental');

        const start = document.getElementById('r-start').value;
        const end   = document.getElementById('r-end').value;
        if (!start || !end) {
            errorMsg.textContent = 'Vui lòng chọn ngày nhận xe và ngày trả xe.';
            errorBox.classList.remove('hidden');
            return;
        }
        if (new Date(end) <= new Date(start)) {
            errorMsg.textContent = 'Ngày trả xe phải sau ngày nhận xe ít nhất 1 ngày.';
            errorBox.classList.remove('hidden');
            return;
        }

        errorBox.classList.add('hidden');
        btn.disabled = true;
        btn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/></svg> Đang xử lý...';

        try {
            const res  = await fetch('/Xe/DatMua', { method: 'POST', body: new FormData(this) });
            const data = await res.json();

            if (data.success) {
                document.getElementById('success-msg').textContent  = data.message;
                document.getElementById('success-code').textContent = data.orderCode;
                document.getElementById('rental-form-panel').classList.add('hidden');
                document.getElementById('rental-success-panel').classList.remove('hidden');
            } else if (data.requireLogin) {
                window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
            } else {
                errorMsg.textContent = data.error || 'Có lỗi xảy ra. Vui lòng thử lại.';
                errorBox.classList.remove('hidden');
                btn.disabled = false;
                btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Xác nhận đặt xe';
            }
        } catch {
            errorMsg.textContent = 'Không thể kết nối. Vui lòng thử lại.';
            errorBox.classList.remove('hidden');
            btn.disabled = false;
            btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Xác nhận đặt xe';
        }
    });
})();
</script>
}
