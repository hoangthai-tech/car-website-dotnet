@{ ViewData["Title"] = "Quên Mật Khẩu"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="min-h-screen bg-gray-50 flex items-center justify-center pt-20 pb-12 px-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <div class="w-12 h-12 bg-brand rounded-xl flex items-center justify-center mx-auto mb-4">
                <span class="text-white font-black text-xl">A</span>
            </div>
            <h1 class="text-2xl font-black text-navy">Đặt lại mật khẩu</h1>
            <p class="text-gray-500 mt-2 text-sm">Nhập email để nhận liên kết đặt lại mật khẩu.</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-8">
            <form asp-controller="Account" asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
                        <input type="email" name="email" required class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30" placeholder="email@example.com" />
                    </div>
                    <button type="submit" class="w-full bg-brand hover:bg-red-700 text-white font-bold py-3.5 rounded-xl transition-colors">
                        Gửi liên kết đặt lại
                    </button>
                    <a asp-controller="Account" asp-action="Login" class="w-full block text-center text-sm text-gray-500 hover:text-brand transition-colors">
                        ← Quay lại đăng nhập
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
