@model CarWebsite.Models.TermsOfService
@{ ViewData["Title"] = "Điều khoản mới cần xác nhận"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="min-h-screen bg-gray-50 flex items-center justify-center pt-20 pb-12 px-4">
    <div class="w-full max-w-2xl">

        <!-- Header -->
        <div class="text-center mb-8">
            <div class="w-14 h-14 bg-amber-500 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
            </div>
            <h1 class="text-2xl font-black text-navy">Điều khoản sử dụng đã được cập nhật</h1>
            <p class="text-gray-500 text-sm mt-2">
                AutoHT ID vừa cập nhật lên <strong class="text-navy">@Model.Version</strong>
                (hiệu lực từ @Model.EffectiveDate.ToString("dd/MM/yyyy")).
                Bạn cần đọc và đồng ý để tiếp tục sử dụng dịch vụ.
            </p>
        </div>

        <!-- Nội dung điều khoản -->
        <div class="bg-white rounded-2xl shadow-sm overflow-hidden mb-6">
            <div class="px-6 py-4 bg-navy flex items-center justify-between">
                <h2 class="text-white font-bold text-sm">ĐIỀU KHOẢN SỬ DỤNG AutoHT ID — @Model.Version</h2>
                <span class="text-white/50 text-xs">Ngày hiệu lực: @Model.EffectiveDate.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="p-6 max-h-96 overflow-y-auto prose max-w-none text-sm" id="termsScrollBox"
                 onscroll="checkScroll(this)">
                @Html.Raw(Model.Content)
            </div>
            <!-- Scroll indicator -->
            <div id="scrollHint" class="px-6 py-3 bg-amber-50 border-t border-amber-100 text-xs text-amber-700 flex items-center gap-2">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
                Vui lòng cuộn xuống để đọc toàn bộ nội dung trước khi đồng ý.
            </div>
        </div>

        <!-- Form đồng ý -->
        <div class="bg-white rounded-2xl shadow-sm p-6">
            <form asp-controller="Account" asp-action="AcceptNewTerms" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="termsId" value="@Model.Id" />

                <div class="border-2 border-gray-200 rounded-xl p-4 bg-gray-50 mb-4 hover:border-brand/40 transition-colors">
                    <label for="agreeNewTerms" class="flex items-start gap-3 cursor-pointer select-none">
                        <div class="flex-shrink-0 mt-0.5">
                            <input type="checkbox" id="agreeNewTerms" name="agreeNewTerms" value="true"
                                   class="sr-only" required
                                   onchange="
                                       const box = document.getElementById('newTermCheckBox');
                                       const mark = document.getElementById('newTermCheckMark');
                                       const btn = document.getElementById('agreeBtn');
                                       if(this.checked){
                                           box.classList.add('bg-brand','border-brand');
                                           box.classList.remove('border-gray-300');
                                           mark.classList.remove('hidden');
                                           btn.disabled = false;
                                           btn.classList.remove('opacity-50','cursor-not-allowed');
                                       } else {
                                           box.classList.remove('bg-brand','border-brand');
                                           box.classList.add('border-gray-300');
                                           mark.classList.add('hidden');
                                           btn.disabled = true;
                                           btn.classList.add('opacity-50','cursor-not-allowed');
                                       }
                                   " />
                            <div id="newTermCheckBox"
                                 class="w-6 h-6 border-2 border-gray-300 rounded-md flex items-center justify-center transition-all duration-150 shadow-sm">
                                <svg id="newTermCheckMark" class="w-3.5 h-3.5 text-white hidden"
                                     fill="none" stroke="currentColor" stroke-width="3.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                                </svg>
                            </div>
                        </div>
                        <span class="text-sm text-gray-700 leading-relaxed">
                            Tôi xác nhận đã đọc đầy đủ và <strong>đồng ý</strong> với
                            Điều khoản Sử dụng AutoHT ID phiên bản <strong class="text-navy">@Model.Version</strong>,
                            có hiệu lực từ ngày <strong>@Model.EffectiveDate.ToString("dd/MM/yyyy")</strong>.
                        </span>
                    </label>
                </div>

                <button type="submit" id="agreeBtn" disabled
                        class="w-full bg-brand text-white font-bold py-3.5 rounded-xl transition-colors
                               opacity-50 cursor-not-allowed hover:bg-red-700 flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Tôi đồng ý và tiếp tục
                </button>

                <p class="text-center text-xs text-gray-400 mt-4">
                    Nếu không đồng ý, bạn có thể
                    <a asp-controller="Account" asp-action="Logout" class="text-brand hover:underline">đăng xuất</a>
                    và liên hệ
                    <a href="mailto:support@autoht.vn" class="text-brand hover:underline">support@autoht.vn</a>
                    để được hỗ trợ.
                </p>
            </form>
        </div>
    </div>
</div>

<script>
    function checkScroll(el) {
        const atBottom = el.scrollTop + el.clientHeight >= el.scrollHeight - 30;
        if (atBottom) {
            document.getElementById('scrollHint').classList.add('hidden');
        }
    }
</script>

<style>
    .prose h2 { font-size: 1.1rem; font-weight: 800; color: #001C3D; margin: 1rem 0 0.4rem; }
    .prose h3 { font-size: 0.95rem; font-weight: 700; color: #001C3D; margin: 0.8rem 0 0.3rem; }
    .prose p  { margin: 0.4rem 0; color: #374151; line-height: 1.65; }
    .prose ul { margin: 0.4rem 0 0.4rem 1.5rem; list-style: disc; color: #374151; }
    .prose li { margin: 0.2rem 0; }
    .prose hr { border-color: #e5e7eb; margin: 1rem 0; }
    .prose strong { color: #001C3D; }
</style>
