@using CarWebsite.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var featuredCars = ViewBag.FeaturedCars as List<Car> ?? [];
    var heroCars    = ViewBag.HeroCars    as List<Car> ?? [];
    var latestNews  = ViewBag.LatestNews  as List<News> ?? [];
}

@* ── HERO SLIDESHOW ── *@
<section class="relative h-screen min-h-[600px] overflow-hidden" id="hero">

    @* Slides *@
    <div id="slides" class="absolute inset-0">
        @for (int i = 0; i < heroCars.Count; i++)
        {
            var car = heroCars[i];
            <div class="slide absolute inset-0 @(i == 0 ? "opacity-100" : "opacity-0") transition-opacity duration-1000">
                @* Ken Burns image *@
                <div class="kb-wrap absolute inset-0 overflow-hidden">
                    <img src="@car.Image.Replace("w=800", "w=1920").Replace("q=80", "q=90")"
                         alt="@car.Name"
                         class="kb-img w-full h-full object-cover"
                         style="transform-origin:center center;" />
                </div>
                <div class="hero-overlay absolute inset-0"></div>
            </div>
        }
    </div>

    @* Content *@
    <div class="relative z-10 h-full flex items-center pb-28">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-24">
            <div class="max-w-2xl">
                @* Badge *@
                <div id="hero-badge" class="inline-block bg-brand/90 backdrop-blur-sm text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-5 transition-all duration-500">
                    @(heroCars.Count > 0 ? heroCars[0].Brand + " • " + heroCars[0].Year : "AutoHT")
                </div>
                @* Title *@
                <h1 id="hero-title" class="text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-tight mb-3 transition-all duration-500">
                    @(heroCars.Count > 0 ? heroCars[0].Name : "Xe Sang Trọng")
                </h1>
                @* Price *@
                <p id="hero-price" class="text-brand text-3xl font-black mb-4 transition-all duration-500">
                    @(heroCars.Count > 0 ? heroCars[0].PriceDisplay : "")
                </p>
                <p class="text-white/75 text-base leading-relaxed mb-8 max-w-md">
                    Trải nghiệm lái đỉnh cao với những mẫu xe sang trọng hàng đầu thế giới.
                </p>
                <div class="flex flex-wrap gap-3">
                    <a id="hero-cta" href="/xe/@(heroCars.Count > 0 ? heroCars[0].Slug : "")"
                       class="inline-flex items-center gap-2 bg-brand hover:bg-red-700 text-white font-semibold px-6 py-3 rounded-xl transition-all hover:scale-105">
                        Xem xe này →
                    </a>
                    <a asp-controller="Xe" asp-action="Index"
                       class="inline-flex items-center gap-2 border-2 border-white/60 hover:border-white text-white font-semibold px-6 py-3 rounded-xl transition-colors">
                        Tất cả xe
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* Dots navigation *@
    <div class="absolute bottom-24 left-0 right-0 z-20 flex justify-center gap-2.5" id="dots">
        @for (int i = 0; i < heroCars.Count; i++)
        {
            <button onclick="goSlide(@i)"
                    class="dot w-2.5 h-2.5 rounded-full transition-all duration-300 @(i == 0 ? "bg-brand scale-125" : "bg-white/50 hover:bg-white")"
                    data-index="@i"></button>
        }
    </div>

    @* Progress bar *@
    <div class="absolute bottom-0 left-0 right-0 z-20 h-0.5 bg-white/10">
        <div id="progress-bar" class="h-full bg-brand" style="width:0%;transition:width linear;"></div>
    </div>

    @* Stats bar *@
    <div class="absolute bottom-0 left-0 right-0 z-10 bg-navy/90 backdrop-blur-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
            @foreach (var stat in new[] { ("500+","Xe Có Sẵn"), ("15+","Năm Kinh Nghiệm"), ("20,000+","Khách Hàng"), ("98%","Hài Lòng") })
            {
                <div>
                    <p class="text-2xl font-black text-white">@stat.Item1</p>
                    <p class="text-white/60 text-xs">@stat.Item2</p>
                </div>
            }
        </div>
    </div>
</section>

@* Slideshow data & script *@
@if (heroCars.Count > 0)
{
    <script>
        const HERO_CARS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(heroCars.Select(c => new {
            name  = c.Name,
            brand = c.Brand,
            year  = c.Year,
            price = c.PriceDisplay,
            slug  = c.Slug
        })));
        const INTERVAL = 6000;

        let current = 0, timer, progressTimer, progressStart;
        const slides   = document.querySelectorAll('.slide');
        const dots     = document.querySelectorAll('.dot');
        const bar      = document.getElementById('progress-bar');

        function goSlide(n) {
            slides[current].classList.replace('opacity-100','opacity-0');
            dots[current].classList.remove('bg-brand','scale-125');
            dots[current].classList.add('bg-white/50');

            // Stop Ken Burns on old slide
            slides[current].querySelector('.kb-img').style.animation = 'none';

            current = (n + slides.length) % slides.length;

            slides[current].classList.replace('opacity-0','opacity-100');
            dots[current].classList.add('bg-brand','scale-125');
            dots[current].classList.remove('bg-white/50');

            // Ken Burns on new slide
            const img = slides[current].querySelector('.kb-img');
            img.style.animation = 'none';
            void img.offsetWidth; // reflow
            img.style.animation = 'kenBurns 8s ease-out forwards';

            // Update text
            const c = HERO_CARS[current];
            updateText('hero-badge', c.brand + ' • ' + c.year);
            updateText('hero-title', c.name);
            updateText('hero-price', c.price);
            document.getElementById('hero-cta').href = '/xe/' + c.slug;

            resetProgress();
        }

        function updateText(id, val) {
            const el = document.getElementById(id);
            el.style.opacity = '0';
            el.style.transform = 'translateY(10px)';
            setTimeout(() => {
                el.textContent = val;
                el.style.transition = 'opacity .4s, transform .4s';
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
            }, 200);
        }

        function resetProgress() {
            bar.style.transition = 'none';
            bar.style.width = '0%';
            clearTimeout(timer);
            setTimeout(() => {
                bar.style.transition = 'width ' + INTERVAL + 'ms linear';
                bar.style.width = '100%';
            }, 30);
            timer = setTimeout(() => goSlide(current + 1), INTERVAL);
        }

        // Start
        slides[0].querySelector('.kb-img').style.animation = 'kenBurns 8s ease-out forwards';
        resetProgress();
    </script>
    <style>
        @@keyframes kenBurns {
            0%   { transform: scale(1)    translateX(0)     translateY(0); }
            100% { transform: scale(1.12) translateX(-2%)   translateY(-1%); }
        }
    </style>
}

@* WHY US *@
<section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 fade-in">
        <div class="text-center mb-12">
            <div class="section-line mx-auto mb-4"></div>
            <h2 class="text-3xl sm:text-4xl font-black text-navy mb-3">Tại Sao Chọn AutoHT?</h2>
            <p class="text-gray-500 max-w-xl mx-auto">Chúng tôi cam kết mang đến trải nghiệm mua xe và thuê xe hoàn hảo nhất.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @foreach (var item in new[] {
                ("🛡️","Bảo Hành Chính Hãng","5 năm hoặc 150.000 km bảo hành toàn diện, không lo hỏng vặt."),
                ("🏆","Xe Chính Hãng 100%","Cam kết nhập khẩu nguyên chiếc, có giấy tờ kiểm định đầy đủ."),
                ("💳","Tài Chính Linh Hoạt","Trả góp 0% lãi suất 12 tháng, hỗ trợ vay tới 80% giá xe."),
                ("🎧","Hỗ Trợ 24/7","Đội ngũ tư vấn chuyên nghiệp, sẵn sàng phục vụ mọi lúc.")
            })
            {
                <div class="bg-white rounded-2xl p-6 text-center shadow-sm hover:shadow-lg transition-shadow group">
                    <div class="text-4xl mb-4">@item.Item1</div>
                    <h3 class="font-bold text-navy mb-2">@item.Item2</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">@item.Item3</p>
                </div>
            }
        </div>
    </div>
</section>

@* FEATURED CARS *@
<section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 fade-in">
        <div class="flex items-end justify-between mb-12">
            <div>
                <div class="section-line mb-4"></div>
                <h2 class="text-3xl sm:text-4xl font-black text-navy">Xe Nổi Bật</h2>
                <p class="text-gray-500 mt-2">Những mẫu xe được khách hàng quan tâm nhiều nhất.</p>
            </div>
            <a asp-controller="Xe" asp-action="Index" class="hidden sm:flex items-center gap-1.5 text-brand font-semibold hover:gap-3 transition-all text-sm">
                Xem tất cả →
            </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var car in featuredCars)
            {
                <a asp-controller="Xe" asp-action="Detail" asp-route-slug="@car.Slug"
                   class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100">
                    <div class="relative h-52 overflow-hidden">
                        <img src="@car.Image" alt="@car.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        @if (!string.IsNullOrEmpty(car.Badge))
                        {
                            <span class="absolute top-3 left-3 bg-brand text-white text-xs font-bold px-2.5 py-1 rounded-full">@car.Badge</span>
                        }
                        <span class="absolute top-3 right-3 bg-white/90 text-navy text-xs font-semibold px-2.5 py-1 rounded-full">@car.Fuel</span>
                    </div>
                    <div class="p-5">
                        <p class="text-xs text-gray-400 mb-1">@car.Brand • @car.Year</p>
                        <h3 class="font-bold text-navy text-lg mb-2 group-hover:text-brand transition-colors">@car.Name</h3>
                        <p class="text-brand font-black text-xl mb-4">@car.PriceDisplay</p>
                        <div class="flex justify-between text-xs text-gray-500 border-t pt-3">
                            <span>@car.Type</span>
                            @{
                                var seats = car.Specs.GetValueOrDefault("seats", "5");
                            }
                            <span>@seats chỗ</span>
                            <span>@car.Specs.GetValueOrDefault("power", "")</span>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

@* LOAN CALCULATOR *@
<section class="py-20 bg-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 fade-in">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
            <div class="text-white">
                <div class="section-line mb-4"></div>
                <h2 class="text-3xl sm:text-4xl font-black mb-4">Tính Toán Tài Chính</h2>
                <p class="text-white/70 leading-relaxed mb-6">Dễ dàng lên kế hoạch tài chính khi mua xe với công cụ tính lãi suất trực tuyến.</p>
                <div class="space-y-5" id="calc-controls">
                    <div>
                        <div class="flex justify-between text-sm mb-2">
                            <span class="text-white/70">Số tiền vay</span>
                            <span class="font-semibold" id="loan-amount-label">2,000 triệu ₫</span>
                        </div>
                        <input type="range" min="200" max="10000" step="100" value="2000" id="loan-amount" class="w-full accent-brand" />
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-2">
                            <span class="text-white/70">Thời hạn vay</span>
                            <span class="font-semibold" id="loan-months-label">60 tháng</span>
                        </div>
                        <input type="range" min="12" max="84" step="12" value="60" id="loan-months" class="w-full accent-brand" />
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-2">
                            <span class="text-white/70">Lãi suất / năm</span>
                            <span class="font-semibold" id="loan-rate-label">7.5%</span>
                        </div>
                        <input type="range" min="5" max="15" step="0.5" value="7.5" id="loan-rate" class="w-full accent-brand" />
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-3xl p-8">
                <p class="text-gray-500 text-sm mb-2">Ước tính trả hàng tháng</p>
                <p class="text-5xl font-black text-brand mb-1" id="monthly-result">17 <span class="text-xl font-semibold text-gray-400">triệu ₫</span></p>
                <p class="text-gray-400 text-sm mb-6" id="monthly-exact">17,000,000 ₫ / tháng</p>
                <div class="space-y-3 border-t pt-5">
                    <div class="flex justify-between text-sm"><span class="text-gray-500">Số tiền vay</span><span class="font-semibold text-navy" id="r-amount">2,000 triệu ₫</span></div>
                    <div class="flex justify-between text-sm"><span class="text-gray-500">Thời hạn</span><span class="font-semibold text-navy" id="r-months">60 tháng</span></div>
                    <div class="flex justify-between text-sm"><span class="text-gray-500">Lãi suất</span><span class="font-semibold text-navy" id="r-rate">7.5% / năm</span></div>
                    <div class="flex justify-between text-sm"><span class="text-gray-500">Tổng lãi ước tính</span><span class="font-semibold text-navy" id="r-interest">396 triệu ₫</span></div>
                </div>
                <a asp-controller="LienHe" asp-action="Index" class="mt-6 w-full inline-block text-center bg-navy hover:bg-navy/90 text-white font-semibold py-3 rounded-xl transition-colors">
                    Tư Vấn Vay Ngay
                </a>
            </div>
        </div>
    </div>
</section>

@* NEWS *@
<section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 fade-in">
        <div class="flex items-end justify-between mb-12">
            <div>
                <div class="section-line mb-4"></div>
                <h2 class="text-3xl sm:text-4xl font-black text-navy">Tin Tức & Ưu Đãi</h2>
            </div>
            <a asp-controller="TinTuc" asp-action="Index" class="hidden sm:flex items-center gap-1.5 text-brand font-semibold text-sm hover:gap-3 transition-all">
                Xem tất cả →
            </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            @foreach (var n in latestNews)
            {
                <a asp-controller="TinTuc" asp-action="Detail" asp-route-slug="@n.Slug" class="group block">
                    <div class="rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
                        <div class="relative h-48 overflow-hidden">
                            <img src="@n.Image" alt="@n.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                            <span class="absolute top-3 left-3 bg-brand text-white text-xs font-semibold px-2.5 py-1 rounded-full">@n.Category</span>
                        </div>
                        <div class="p-5 bg-white">
                            <p class="text-xs text-gray-400 mb-2">@n.PublishedAt.ToString("dd/MM/yyyy") · @n.ReadTime đọc</p>
                            <h3 class="font-bold text-navy leading-snug mb-2 group-hover:text-brand transition-colors line-clamp-2">@n.Title</h3>
                            <p class="text-gray-500 text-sm line-clamp-2">@n.Excerpt</p>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

@* CTA *@
<section class="relative py-20 overflow-hidden">
    <img src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=1920&q=80" alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-navy/80"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center text-white">
        <h2 class="text-4xl sm:text-5xl font-black mb-4">Sẵn Sàng Trải Nghiệm?</h2>
        <p class="text-white/80 text-lg mb-8">Đặt lịch lái thử miễn phí hôm nay. Đội ngũ tư vấn sẽ liên hệ trong vòng 30 phút.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-controller="Xe" asp-action="Index" class="inline-flex items-center justify-center gap-2 bg-brand hover:bg-red-700 text-white font-bold px-8 py-4 rounded-xl transition-all hover:scale-105">
                Xem Xe Ngay →
            </a>
            <a asp-controller="ThueXe" asp-action="Index" class="inline-flex items-center justify-center gap-2 border-2 border-white hover:bg-white hover:text-navy text-white font-bold px-8 py-4 rounded-xl transition-all">
                Thuê Xe Ngay
            </a>
        </div>
    </div>
</section>

@section Scripts {
<script>
    function calcLoan() {
        const p = parseFloat(document.getElementById('loan-amount').value) * 1e6;
        const n = parseInt(document.getElementById('loan-months').value);
        const r = parseFloat(document.getElementById('loan-rate').value) / 100 / 12;
        const monthly = r === 0 ? p / n : (p * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
        const interest = monthly * n - p;
        const amt = parseFloat(document.getElementById('loan-amount').value);
        document.getElementById('loan-amount-label').textContent = amt.toLocaleString('vi') + ' triệu ₫';
        document.getElementById('loan-months-label').textContent = n + ' tháng';
        document.getElementById('loan-rate-label').textContent = document.getElementById('loan-rate').value + '%';
        document.getElementById('monthly-result').innerHTML = Math.round(monthly / 1e6).toLocaleString('vi') + ' <span class="text-xl font-semibold text-gray-400">triệu ₫</span>';
        document.getElementById('monthly-exact').textContent = Math.round(monthly).toLocaleString('vi') + ' ₫ / tháng';
        document.getElementById('r-amount').textContent = amt.toLocaleString('vi') + ' triệu ₫';
        document.getElementById('r-months').textContent = n + ' tháng';
        document.getElementById('r-rate').textContent = document.getElementById('loan-rate').value + '% / năm';
        document.getElementById('r-interest').textContent = Math.round(interest / 1e6).toLocaleString('vi') + ' triệu ₫';
    }
    ['loan-amount','loan-months','loan-rate'].forEach(id => document.getElementById(id).addEventListener('input', calcLoan));
    calcLoan();
</script>
}
