@using CarWebsite.Models
@model List<Car>
@{
    ViewData["Title"] = "So sánh xe";
    var cars = Model ?? [];

    // Hàng thông tin cơ bản — thêm Func<Car,double>? để so sánh số
    var basicRows = new (string Label, Func<Car, string> Get, Func<Car, double>? Num)[]
    {
        ("Thương hiệu",     c => c.Brand,     null),
        ("Năm sản xuất",    c => c.Year.ToString(), c => (double)c.Year),
        ("Loại xe",         c => c.Type,      null),
        ("Nhiên liệu",      c => c.Fuel,      null),
        ("Giá niêm yết",    c => c.PriceDisplay, c => (double)c.Price),
        ("Giá thuê / ngày", c => c.RentalPricePerDay > 0 ? c.RentalPricePerDay.ToString("N0") + " ₫" : "—",
                            c => c.RentalPricePerDay > 0 ? (double)c.RentalPricePerDay : double.NaN),
    };

    // Hàng thông số kỹ thuật — bool HasNum = true thì dùng ParseNum()
    var specRows = new (string Label, string Key, bool HasNum)[]
    {
        ("Động cơ",              "engine",          false),
        ("Công suất",            "power",           true),
        ("Mô-men xoắn",         "torque",          true),
        ("Hộp số",               "transmission",    false),
        ("Tăng tốc 0–100 km/h", "acceleration",    true),
        ("Tốc độ tối đa",       "topSpeed",        true),
        ("Tiêu thụ nhiên liệu", "fuelConsumption", true),
        ("Số chỗ ngồi",         "seats",           true),
    };
}

@* ── Helper: mũi tên so sánh ── *@
@functions {
    // Trích số đầu tiên từ chuỗi thông số kỹ thuật ("585 mã lực" → 585.0)
    static double? ParseNum(string? s)
    {
        if (string.IsNullOrWhiteSpace(s) || s == "—") return null;
        var m = System.Text.RegularExpressions.Regex.Match(s, @"\d+(?:[.,]\d+)?");
        if (!m.Success) return null;
        var clean = m.Value.Replace(",", ".");
        return double.TryParse(clean, System.Globalization.NumberStyles.Number,
               System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : null;
    }

    // Tính mảng: true nếu ô đó là cao nhất / thấp nhất trong hàng
    static (bool[] IsHighest, bool[] IsLowest) CalcArrows(double?[] nums)
    {
        int n = nums.Length;
        var isH = new bool[n];
        var isL = new bool[n];
        var valid = nums.Where(x => x.HasValue && !double.IsNaN(x!.Value))
                        .Select(x => x!.Value).Distinct().ToList();
        if (valid.Count < 2) return (isH, isL);

        double mx = valid.Max(), mn = valid.Min();
        for (int i = 0; i < n; i++)
        {
            if (!nums[i].HasValue || double.IsNaN(nums[i]!.Value)) continue;
            isH[i] = nums[i]!.Value == mx;
            isL[i] = nums[i]!.Value == mn;
        }
        return (isH, isL);
    }
}

<div class="pt-24 pb-20 min-h-screen bg-gray-50">
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    @* Breadcrumb *@
    <nav class="text-sm text-gray-500 mb-6">
        <a asp-controller="Home" asp-action="Index" class="hover:text-brand">Trang chủ</a>
        <span class="mx-2">/</span>
        <a asp-controller="Xe" asp-action="Index" class="hover:text-brand">Xe</a>
        <span class="mx-2">/</span>
        <span class="text-gray-800">So sánh xe</span>
    </nav>

    <div class="mb-8">
        <div class="section-line mb-3"></div>
        <h1 class="text-3xl sm:text-4xl font-black text-navy">So Sánh Xe</h1>
        <p class="text-gray-500 mt-2">Đối chiếu thông số kỹ thuật để chọn xe phù hợp nhất</p>
    </div>

    @if (!cars.Any())
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-5">
                <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
            </div>
            <h3 class="text-xl font-black text-navy mb-2">Chưa có xe nào để so sánh</h3>
            <p class="text-gray-500 text-sm mb-6">Hãy vào trang danh sách xe, nhấn nút <strong>"So sánh"</strong> trên card xe để thêm vào danh sách.</p>
            <a asp-controller="Xe" asp-action="Index"
               class="inline-block bg-brand hover:bg-red-700 text-white font-bold px-6 py-3 rounded-xl transition-colors">
                Xem tất cả xe →
            </a>
        </div>
    }
    else if (cars.Count == 1)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 flex items-center gap-6">
            <img src="@cars[0].Image" alt="@cars[0].Name" class="w-36 h-24 object-cover rounded-xl flex-shrink-0" />
            <div class="flex-1">
                <h3 class="text-lg font-black text-navy">@cars[0].Name</h3>
                <p class="text-brand font-black text-xl mt-1">@cars[0].PriceDisplay</p>
                <p class="text-gray-400 text-sm mt-2">Cần ít nhất <strong>2 xe</strong> để bắt đầu so sánh.</p>
            </div>
            <div class="flex flex-col gap-3">
                <a asp-controller="Xe" asp-action="Index"
                   class="bg-brand hover:bg-red-700 text-white text-sm font-bold px-5 py-2.5 rounded-xl transition-colors whitespace-nowrap">
                    + Thêm xe khác
                </a>
                <button onclick="ssRemove('@cars[0].Slug');window.location.href='/SoSanh'"
                        class="border border-gray-200 hover:bg-gray-50 text-gray-600 text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors whitespace-nowrap">
                    Xóa xe này
                </button>
            </div>
        </div>
    }
    else
    {
        @* Ghi chú mũi tên *@
        <div class="flex items-center gap-4 mb-4 text-xs text-gray-400">
            <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/></svg>
                Cao nhất
            </span>
            <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                Thấp nhất
            </span>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full border-collapse" style="min-width:600px;">

                    @* ── Header: ảnh + tên + nút xóa ── *@
                    <thead>
                        <tr class="border-b-2 border-gray-100">
                            <th class="w-40 p-5 text-left bg-gray-50 border-r border-gray-100">
                                <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Thông số</span>
                            </th>
                            @foreach (var car in cars)
                            {
                                <th class="p-5 text-center align-top" style="min-width:220px;">
                                    <div class="flex flex-col items-center gap-3">
                                        <div class="relative">
                                            <img src="@car.Image" alt="@car.Name"
                                                 class="w-full h-36 object-cover rounded-xl"
                                                 style="max-width:200px;" />
                                            @if (!string.IsNullOrEmpty(car.Badge))
                                            {
                                                <span class="absolute top-2 left-2 bg-brand text-white text-xs font-bold px-2 py-0.5 rounded-full">@car.Badge</span>
                                            }
                                        </div>
                                        <div>
                                            <p class="text-xs text-gray-400">@car.Brand • @car.Year</p>
                                            <h3 class="font-black text-navy text-base leading-tight mt-0.5">@car.Name</h3>
                                            <p class="text-brand font-black text-lg mt-1">@car.PriceDisplay</p>
                                        </div>
                                        <button
                                            onclick="ssRemove('@car.Slug'); location.href = buildSoSanhUrl('@car.Slug');"
                                            class="flex items-center gap-1.5 text-xs text-gray-400 hover:text-red-500 border border-gray-200 hover:border-red-300 px-3 py-1.5 rounded-xl transition-colors">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                            </svg>
                                            Xóa khỏi so sánh
                                        </button>
                                    </div>
                                </th>
                            }
                            @if (cars.Count == 2)
                            {
                                <th class="p-5 border-l border-dashed border-gray-200 bg-gray-50/50" style="min-width:220px;">
                                    <div class="flex flex-col items-center justify-center gap-3 py-6">
                                        <div class="w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center">
                                            <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
                                            </svg>
                                        </div>
                                        <p class="text-gray-400 text-xs text-center">Thêm xe thứ 3<br/>để so sánh</p>
                                        <a asp-controller="Xe" asp-action="Index"
                                           class="text-xs font-semibold text-brand hover:underline">Xem xe →</a>
                                    </div>
                                </th>
                            }
                        </tr>
                    </thead>

                    <tbody>

                        @* ── NHÓM: Thông tin cơ bản ── *@
                        <tr class="bg-gray-50">
                            <td colspan="@(cars.Count + (cars.Count < 3 ? 2 : 1))"
                                class="px-5 py-2.5 text-xs font-black text-gray-500 uppercase tracking-widest border-b border-gray-100">
                                Thông tin cơ bản
                            </td>
                        </tr>

                        @foreach (var row in basicRows)
                        {
                            var values = cars.Select(c => row.Get(c)).ToList();
                            // Tính mảng số để so sánh
                            var nums = row.Num != null
                                ? cars.Select(c => { var n = row.Num(c); return double.IsNaN(n) ? (double?)null : n; }).ToArray()
                                : new double?[cars.Count];
                            var (isHighest, isLowest) = CalcArrows(nums);

                            bool isPriceRow = row.Label == "Giá niêm yết";
                            <tr class="border-b border-gray-50 hover:bg-amber-50/30 transition-colors">
                                <td class="px-5 py-3.5 text-sm font-semibold text-gray-600 bg-gray-50 border-r border-gray-100 whitespace-nowrap">
                                    @row.Label
                                </td>
                                @for (int ci = 0; ci < values.Count; ci++)
                                {
                                    var val = values[ci];
                                    bool hi = isHighest[ci], lo = isLowest[ci];
                                    bool isCheapest = isPriceRow && lo;
                                    <td class="px-5 py-3.5 text-center border-r border-gray-50 @(isCheapest ? "bg-green-50" : "")">
                                        <div class="inline-flex items-center justify-center gap-1">
                                            <span class="text-sm font-@(isPriceRow ? "black text-brand" : "medium text-navy")">
                                                @val
                                            </span>
                                            @if (hi)
                                            {
                                                <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/>
                                                </svg>
                                            }
                                            else if (lo)
                                            {
                                                <svg class="w-3.5 h-3.5 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                                                </svg>
                                            }
                                        </div>
                                        @if (isCheapest && nums.Where(n => n.HasValue).Select(n => n!.Value).Distinct().Count() > 1)
                                        {
                                            <div class="mt-1">
                                                <span class="bg-green-100 text-green-700 text-xs font-bold px-1.5 py-0.5 rounded-full">Thấp nhất</span>
                                            </div>
                                        }
                                    </td>
                                }
                                @if (cars.Count == 2)
                                {
                                    <td class="border-l border-dashed border-gray-100 bg-gray-50/30"></td>
                                }
                            </tr>
                        }

                        @* ── NHÓM: Thông số kỹ thuật ── *@
                        <tr class="bg-gray-50">
                            <td colspan="@(cars.Count + (cars.Count < 3 ? 2 : 1))"
                                class="px-5 py-2.5 text-xs font-black text-gray-500 uppercase tracking-widest border-b border-gray-100">
                                Thông số kỹ thuật
                            </td>
                        </tr>

                        @foreach (var row in specRows)
                        {
                            var values = cars.Select(c => c.Specs.GetValueOrDefault(row.Key, "—")).ToList();
                            var nums = row.HasNum
                                ? values.Select(v => ParseNum(v)).ToArray()
                                : new double?[cars.Count];
                            var (isHighest, isLowest) = CalcArrows(nums);

                            <tr class="border-b border-gray-50 hover:bg-blue-50/20 transition-colors">
                                <td class="px-5 py-3.5 text-sm font-semibold text-gray-600 bg-gray-50 border-r border-gray-100 whitespace-nowrap">
                                    @row.Label
                                </td>
                                @for (int ci = 0; ci < values.Count; ci++)
                                {
                                    var val = values[ci];
                                    bool hi = isHighest[ci], lo = isLowest[ci];
                                    <td class="px-5 py-3.5 text-center border-r border-gray-50">
                                        <div class="inline-flex items-center justify-center gap-1">
                                            <span class="text-sm text-navy">@(string.IsNullOrEmpty(val) || val == "—" ? "—" : val)</span>
                                            @if (hi)
                                            {
                                                <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/>
                                                </svg>
                                            }
                                            else if (lo)
                                            {
                                                <svg class="w-3.5 h-3.5 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                                                </svg>
                                            }
                                        </div>
                                    </td>
                                }
                                @if (cars.Count == 2)
                                {
                                    <td class="border-l border-dashed border-gray-100 bg-gray-50/30"></td>
                                }
                            </tr>
                        }

                        @* ── NHÓM: Tính năng nổi bật ── *@
                        <tr class="bg-gray-50">
                            <td colspan="@(cars.Count + (cars.Count < 3 ? 2 : 1))"
                                class="px-5 py-2.5 text-xs font-black text-gray-500 uppercase tracking-widest border-b border-gray-100">
                                Tính năng nổi bật
                            </td>
                        </tr>
                        <tr class="border-b border-gray-50">
                            <td class="px-5 py-3 text-sm font-semibold text-gray-600 bg-gray-50 border-r border-gray-100">
                                Trang bị
                            </td>
                            @foreach (var car in cars)
                            {
                                <td class="px-5 py-3 border-r border-gray-50 align-top">
                                    @if (car.Features.Any())
                                    {
                                        <div class="flex flex-wrap gap-1.5">
                                            @foreach (var feat in car.Features.Take(6))
                                            {
                                                <span class="bg-blue-50 text-blue-700 text-xs px-2 py-0.5 rounded-full">@feat</span>
                                            }
                                            @if (car.Features.Count > 6)
                                            {
                                                <span class="text-gray-400 text-xs">+@(car.Features.Count - 6) tính năng</span>
                                            }
                                        </div>
                                    }
                                    else { <span class="text-gray-300 text-xs">—</span> }
                                </td>
                            }
                            @if (cars.Count == 2)
                            {
                                <td class="border-l border-dashed border-gray-100 bg-gray-50/30"></td>
                            }
                        </tr>

                        @* ── Footer: CTA ── *@
                        <tr class="bg-gray-50">
                            <td class="p-5 border-r border-gray-100"></td>
                            @foreach (var car in cars)
                            {
                                <td class="p-5 text-center border-r border-gray-50">
                                    <div class="flex flex-col gap-2">
                                        <a asp-controller="Xe" asp-action="Detail" asp-route-slug="@car.Slug"
                                           class="block bg-navy hover:bg-navy/80 text-white text-sm font-bold py-2.5 rounded-xl transition-colors">
                                            Xem chi tiết
                                        </a>
                                        <button
                                            onclick="window.location.href='/xe/@car.Slug#dat-mua'"
                                            class="block w-full bg-brand hover:bg-red-700 text-white text-sm font-bold py-2.5 rounded-xl transition-colors">
                                            Đặt mua ngay
                                        </button>
                                    </div>
                                </td>
                            }
                            @if (cars.Count == 2)
                            {
                                <td class="border-l border-dashed border-gray-100 bg-gray-50/30"></td>
                            }
                        </tr>

                    </tbody>
                </table>
            </div>
        </div>
    }

</div>
</div>

@section Scripts {
<script>
function buildSoSanhUrl(removedSlug) {
    const list = JSON.parse(localStorage.getItem('soSanhList') || '[]')
                      .filter(x => x.slug !== removedSlug);
    if (!list.length) return '/SoSanh';
    const params = list.map((x, i) => `slug${i+1}=${encodeURIComponent(x.slug)}`).join('&');
    return '/SoSanh?' + params;
}
</script>
}
